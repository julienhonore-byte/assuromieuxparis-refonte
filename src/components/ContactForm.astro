<form class="card form-grid" action="https://formspree.io/f/mnjlwzlp" method="POST">
  <div class="form-field">
    <label for="contact-first-name">Prénom</label>
    <input id="contact-first-name" name="prenom" type="text" autocomplete="given-name" required />
  </div>
  <div class="form-field">
    <label for="contact-last-name">Nom</label>
    <input id="contact-last-name" name="nom" type="text" autocomplete="family-name" required />
  </div>
  <div class="form-field">
    <label for="contact-email">Email professionnel</label>
    <input id="contact-email" name="email" type="email" autocomplete="email" required />
  </div>
  <div class="form-field">
    <label for="contact-phone">Téléphone</label>
    <input id="contact-phone" name="telephone" type="tel" autocomplete="tel" />
  </div>
  <div class="form-field form-field--full">
    <label for="contact-message">Votre besoin</label>
    <textarea id="contact-message" name="message"></textarea>
  </div>
  <input type="hidden" name="source" value="Socle Astro Assuromieux Paris" />
  <p class="form-note">Formulaire de démonstration technique. Ne pas envoyer de données réelles depuis l'environnement local.</p>
  <button class="button button--primary form-field--full" type="submit">Envoyer la demande</button>
</form>
