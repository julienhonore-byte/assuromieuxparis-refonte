---
import DesktopNavigation from './DesktopNavigation.astro';
import MobileNavigation from './MobileNavigation.astro';
import Topbar from './Topbar.astro';

interface Item {
  href: string;
  label: string;
}

interface Props {
  items?: Item[];
  currentPath?: string;
}

const { items, currentPath = '/' } = Astro.props;
---

<header>
  <Topbar />
  <div class="site-header">
    <div class="container site-header__inner">
      <a class="brand" href="/" aria-label="Assuromieux Paris — Accueil">
        <img src="/logo/assuromieux-paris.jpeg" width="300" height="83" alt="Assuromieux Paris" />
        <span>Paris</span>
      </a>
      <DesktopNavigation {items} {currentPath} />
      <MobileNavigation {items} {currentPath} />
    </div>
  </div>
</header>

<style>
  .site-header {
    background: rgba(255, 255, 255, 0.96);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(16px);
  }

  .site-header__inner {
    min-height: 4.875rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    color: var(--color-blue-dark);
    font-size: 1.125rem;
    font-weight: var(--font-weight-strong);
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  .brand img {
    width: 11.25rem;
    height: auto;
  }

  @media (max-width: 640px) {
    .brand img {
      width: 9.0625rem;
    }
  }
</style>
