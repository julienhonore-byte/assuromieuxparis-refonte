---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  id?: string;
}

const { eyebrow, title, lead, id = 'top' } = Astro.props;
---

<section class="hero" {id}>
  <div class="container-wide hero__grid">
    <div class="hero__copy">
      {eyebrow && <p class="hero__eyebrow"><span aria-hidden="true"></span>{eyebrow}</p>}
      <h1>{title}</h1>
      {lead && <p class="hero__lead">{lead}</p>}
      <div class="hero__content"><slot /></div>
    </div>
    <div class="hero__visual" aria-label="Représentation de l’analyse des risques d’entreprise">
      <slot name="visual" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    padding-block: clamp(4rem, 7.5vw, 7rem);
    background:
      radial-gradient(circle at 78% 16%, rgba(201, 154, 70, 0.22), transparent 24%),
      radial-gradient(circle at 6% 86%, rgba(18, 54, 95, 0.08), transparent 23%),
      linear-gradient(135deg, #ffffff 0%, #f1f6fb 50%, #e4edf6 100%);
  }

  .hero::before {
    position: absolute;
    z-index: -1;
    inset: 0;
    content: '';
    opacity: 0.24;
    background-image:
      linear-gradient(rgba(18, 54, 95, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(18, 54, 95, 0.12) 1px, transparent 1px);
    background-size: 3.5rem 3.5rem;
    mask-image: linear-gradient(to right, transparent, black 45%, black 90%, transparent);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(22rem, 0.92fr);
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
  }

  .hero__copy {
    max-width: 46rem;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0 0 var(--space-6);
    padding: 0.58rem 0.95rem;
    color: var(--color-brand-deep);
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(201, 154, 70, 0.44);
    border-radius: var(--radius-pill);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-heading);
    letter-spacing: 0.04em;
    box-shadow: 0 10px 28px rgba(12, 42, 78, 0.06);
  }

  .hero__eyebrow span {
    width: 0.5rem;
    height: 0.5rem;
    background: var(--color-gold);
    border-radius: 50%;
    box-shadow: 0 0 0 0.3rem rgba(201, 154, 70, 0.13);
  }

  h1 {
    max-width: 12ch;
    margin: 0;
    color: var(--color-brand-ink);
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-heading);
    letter-spacing: var(--letter-spacing-display);
    line-height: var(--line-height-tight);
  }

  .hero__lead {
    max-width: 40rem;
    margin: var(--space-7) 0 0;
    color: var(--color-text-soft);
    font-size: var(--font-size-lead);
    line-height: 1.65;
  }

  .hero__content {
    margin-top: var(--space-8);
  }

  .hero__visual {
    min-width: 0;
  }

  @media (max-width: 980px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .hero__copy {
      max-width: 43rem;
    }

    h1 {
      max-width: 15ch;
    }

    .hero__visual {
      max-width: 43rem;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-block: 3.75rem 4.5rem;
    }

    h1 {
      max-width: none;
    }

    .hero__eyebrow {
      align-items: flex-start;
      border-radius: var(--radius-card-sm);
      line-height: 1.4;
    }
  }
</style>
