---
interface Props {
  phoneDisplay: string;
  phoneHref: string;
  email: string;
  orias: string;
  auditHref?: string;
}

const { phoneDisplay, phoneHref, email, orias, auditHref = '#contact' } = Astro.props;
---

<div class="topbar">
  <div class="container-wide topbar__inner">
    <p class="topbar__positioning">
      <span>Courtage en assurance professionnelle</span>
      <span aria-hidden="true">•</span>
      <span>Paris · Intervention nationale</span>
      <span aria-hidden="true">•</span>
      <span>ORIAS {orias}</span>
    </p>
    <div class="topbar__contact">
      <a href={phoneHref}>{phoneDisplay}</a>
      <a href={`mailto:${email}`}>{email}</a>
      <a class="topbar__audit" href={auditHref}>Analyse gratuite <span aria-hidden="true">→</span></a>
    </div>
  </div>
</div>

<style>
  .topbar {
    padding-block: 0.55rem;
    color: var(--color-text-on-dark);
    background: var(--color-brand-deep);
    font-size: 0.75rem;
  }

  .topbar__inner,
  .topbar__positioning,
  .topbar__contact {
    display: flex;
    align-items: center;
  }

  .topbar__inner {
    justify-content: space-between;
    gap: var(--space-5);
  }

  .topbar__positioning,
  .topbar__contact {
    gap: var(--space-3);
    margin: 0;
  }

  a {
    min-height: 1.75rem;
    display: inline-flex;
    align-items: center;
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    color: var(--color-gold-soft);
    text-decoration: underline;
  }

  .topbar__audit {
    color: var(--color-gold-soft);
    font-weight: var(--font-weight-strong);
  }

  @media (max-width: 1100px) {
    .topbar__positioning span:nth-child(1),
    .topbar__positioning span:nth-child(2) {
      display: none;
    }
  }

  @media (max-width: 980px) {
    a {
      min-height: 2.75rem;
    }
  }

  @media (max-width: 760px) {
    .topbar__inner {
      justify-content: center;
    }

    .topbar__positioning,
    .topbar__contact a:not(.topbar__audit) {
      display: none;
    }

    .topbar__contact {
      width: 100%;
      justify-content: space-between;
    }

    .topbar__contact::before {
      content: 'Paris · France entière';
      color: var(--color-text-on-dark-soft);
    }

    .topbar__audit {
      min-height: 2.75rem;
    }
  }
</style>
