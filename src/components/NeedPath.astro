---
interface Item { title: string; text: string; }
interface Props { id?: string; kicker?: string; title: string; intro: string; items: Item[]; }
const { id = 'parcours', kicker = 'Votre situation', title, intro, items } = Astro.props;
---
<section id={id} class="section need-path" aria-labelledby={`${id}-title`}>
  <div class="container-wide need-path__layout">
    <header><p class="eyebrow">{kicker}</p><h2 id={`${id}-title`}>{title}</h2><p>{intro}</p></header>
    <ol>
      {items.map((item, index) => <li><span>{String(index + 1).padStart(2, '0')}</span><div><h3>{item.title}</h3><p>{item.text}</p></div></li>)}
    </ol>
  </div>
</section>
<style>
  .need-path__layout { display: grid; grid-template-columns: minmax(17rem,.62fr) minmax(0,1.38fr); gap: clamp(3rem,8vw,8rem); align-items: start; }
  header { position: sticky; top: var(--space-6); }
  h2 { max-width: 15ch; margin: 0; color: var(--color-brand-ink); font-size: var(--font-size-h2); line-height: var(--line-height-heading); letter-spacing: var(--letter-spacing-heading); }
  header > p:last-child { max-width: 34rem; margin: var(--space-5) 0 0; color: var(--color-text-soft); }
  ol { margin: 0; padding: 0; border-top: 1px solid var(--color-border); list-style: none; }
  li { display: grid; grid-template-columns: 2.5rem minmax(0,1fr); gap: var(--space-4); padding: var(--space-6) 0; border-bottom: 1px solid var(--color-border); }
  li > span { color: var(--color-gold-dark); font-size: var(--font-size-xs); font-weight: var(--font-weight-heading); }
  h3 { margin: 0; color: var(--color-brand-deep); font-size: var(--font-size-h4); }
  li p { margin: var(--space-2) 0 0; color: var(--color-text-soft); font-size: var(--font-size-sm); }
  @media (max-width: 860px) { .need-path__layout { grid-template-columns: 1fr; } header { position: static; } }
</style>
