---
import ArticleCard from '../components/ArticleCard.astro';
import ContactForm from '../components/ContactForm.astro';
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';
import Hero from '../components/Hero.astro';
import ParisHeroVisual from '../components/ParisHeroVisual.astro';
import ProductSelector from '../components/ProductSelector.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SolutionMethod from '../components/SolutionMethod.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { insuranceProducts } from '../data/products';
import { organizationSchema, site } from '../data/site';

const faqItems = [
  {
    question: 'Que vérifie un audit des assurances d’entreprise ?',
    answer: 'L’audit rapproche l’activité, les risques et les contrats disponibles. Il examine notamment les garanties, exclusions, franchises, déclarations et échéances afin de rendre les arbitrages plus lisibles.',
  },
  {
    question: 'Faut-il changer d’assureur après l’audit ?',
    answer: 'Non. Un contrat peut être conservé, ajusté ou remis en concurrence. La recommandation dépend de sa cohérence avec l’entreprise, pas du changement pour lui-même.',
  },
  {
    question: 'Le cabinet accompagne-t-il d’autres secteurs que le transport ?',
    answer: 'Oui. Assuromieux Paris accompagne différentes entreprises sur leurs assurances professionnelles. Le transport, la logistique et le BTP sont deux expertises sectorielles parmi une approche plus large.',
  },
  {
    question: 'Intervenez-vous en dehors de Paris ?',
    answer: 'Oui. Le cabinet est implanté dans le 8e arrondissement et accompagne des entreprises parisiennes, franciliennes et situées ailleurs en France.',
  },
];

const structuredData = [
  organizationSchema,
  {
    '@context': 'https://schema.org',
    '@type': ['LocalBusiness', 'InsuranceAgency'],
    '@id': `${site.canonicalUrl}#insurance-agency`,
    name: site.name,
    url: site.canonicalUrl,
    image: `${site.canonicalUrl}og-homepage-03.jpg`,
    telephone: '+33695699674',
    email: site.email,
    address: organizationSchema.address,
    areaServed: { '@type': 'Country', name: 'France' },
    parentOrganization: { '@id': `${site.canonicalUrl}#organization` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Assurances professionnelles proposées par Assuromieux Paris',
    itemListElement: insuranceProducts.map((product, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      item: {
        '@type': 'Service',
        name: product.name,
        description: product.description,
        url: new URL(product.href, site.canonicalUrl).toString(),
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  },
];
---

<SiteLayout
  title="Courtier en assurance entreprise à Paris | Assuromieux Paris"
  description="Assuromieux Paris analyse les risques et les contrats des entreprises avant de conseiller, comparer et optimiser leurs assurances professionnelles."
  canonical={site.canonicalUrl}
  currentPath="/"
  ctaHref="#contact"
  {structuredData}
>
  <main id="contenu-principal">
    <Hero
      eyebrow="Conseil & courtage en assurances d’entreprise"
      title="Vos assurances d’entreprise méritent une stratégie, pas un simple renouvellement."
      lead="Assuromieux Paris analyse vos contrats, identifie les risques et consulte le marché pour construire une protection cohérente avec votre activité."
    >
      <div class="hero-actions">
        <CTA href="#contact" label="Demander un audit gratuit" size="large" />
        <CTA href="#produits" label="Voir nos assurances" variant="secondary" size="large" />
      </div>
      <ParisHeroVisual slot="visual" />
    </Hero>

    <section id="produits" class="section products" aria-labelledby="products-title">
      <div class="container-wide">
        <SectionHeader
          kicker="Accès direct"
          title="Quelle assurance recherchez-vous ?"
          text="Choisissez votre besoin pour accéder directement à la page ou au point de contact pertinent."
          id="products-title"
        />
        <ProductSelector products={insuranceProducts} />
      </div>
    </section>

    <section class="section section--surface promise" aria-labelledby="promise-title">
      <div class="container-wide promise__grid">
        <div class="promise__intro">
          <p class="eyebrow">Une vision globale de vos assurances</p>
          <h2 id="promise-title">Relier vos contrats à votre activité réelle.</h2>
          <p>Nous identifions les incohérences, les risques insuffisamment couverts et les conditions qui peuvent être renégociées.</p>
        </div>
        <ol class="promise__steps">
          <li><span>01</span><strong>Analyser</strong><small>Activité, contrats et risques.</small></li>
          <li><span>02</span><strong>Comparer</strong><small>Garanties, conditions et marché.</small></li>
          <li><span>03</span><strong>Accompagner</strong><small>Décisions, mise en œuvre et suivi.</small></li>
        </ol>
      </div>
    </section>

    <section id="secteurs" class="section offer-overview" aria-labelledby="offer-title">
      <div class="container-wide">
        <SectionHeader
          kicker="Produits & expertises"
          title="Une base commune, complétée par deux lectures sectorielles."
          id="offer-title"
        />
        <div class="offer-overview__grid">
          <article>
            <span class="offer-overview__label">Assurances transversales</span>
            <h3>Les protections essentielles de l’entreprise</h3>
            <p>RC professionnelle, multirisque professionnelle, flotte automobile, santé et prévoyance, protection du dirigeant et cyberassurance.</p>
            <a class="link-arrow" href="/assurances-entreprises/">Voir toutes les assurances <span aria-hidden="true">→</span></a>
          </article>
          <article class="offer-overview__sector">
            <span class="offer-overview__label">Expertises sectorielles</span>
            <h3>Transport, logistique, BTP et décennale</h3>
            <p>Deux secteurs où l’exploitation, les responsabilités et les obligations nécessitent une lecture métier plus précise.</p>
            <div class="offer-overview__links">
              <a href="/assurance-transport/">Transport & logistique <span aria-hidden="true">→</span></a>
              <a href="/assurance-btp-decennale/">BTP & décennale <span aria-hidden="true">→</span></a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <SolutionMethod
      title="Comprendre, analyser, consulter, recommander."
      text="L’audit assurance entreprise transforme des contrats techniques en décisions compréhensibles. Le suivi est ensuite adapté aux échéances et aux évolutions de l’activité."
    />

    <section id="cabinet" class="section cabinet-home" aria-labelledby="cabinet-title">
      <div class="container-wide cabinet-home__grid">
        <div class="cabinet-home__place" aria-hidden="true">
          <span>PARIS</span><strong>08</strong><small>Intervention nationale</small>
        </div>
        <div class="cabinet-home__copy">
          <p class="eyebrow">Assuromieux Paris</p>
          <h2 id="cabinet-title">Un cabinet parisien, un accompagnement national.</h2>
          <p>Basé dans le 8e arrondissement, Assuromieux Paris accompagne les entreprises parisiennes, franciliennes et nationales dans l’analyse et l’optimisation de leurs assurances.</p>
          <ul><li>Interlocuteur direct</li><li>Approche accessible</li><li>Accompagnement personnalisé</li></ul>
          <a class="link-arrow" href="/cabinet/">Découvrir le cabinet <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <section id="ressources" class="section section--surface resources" aria-labelledby="resources-title">
      <div class="container-wide">
        <SectionHeader kicker="Ressources" title="Trois repères pour mieux décider." id="resources-title" />
        <div class="article-grid">
          <ArticleCard type="Guide" title="Préparer l’audit de ses assurances" summary="Les documents et questions utiles avant une première analyse." />
          <ArticleCard type="Analyse" title="Lire ses contrats comme un programme" summary="Pourquoi responsabilités, biens, équipes et continuité doivent être rapprochés." />
          <ArticleCard type="Question" title="Faut-il toujours changer d’assureur ?" summary="La recommandation peut aussi conduire à conserver ou ajuster un contrat." />
        </div>
      </div>
    </section>

    <section class="section faq-section" aria-labelledby="faq-title">
      <div class="container faq-layout">
        <SectionHeader kicker="Questions fréquentes" title="L’essentiel avant un premier échange." id="faq-title" />
        <FAQ items={faqItems} />
      </div>
    </section>

    <section id="contact" class="section contact" aria-labelledby="contact-title">
      <div class="container-wide contact__grid">
        <div class="contact__intro">
          <SectionHeader
            kicker="Premier échange"
            title="Faisons le point sur votre besoin prioritaire."
            text="Présentez votre activité et le contrat concerné. Aucun document confidentiel n’est nécessaire à ce stade."
            tone="dark"
            id="contact-title"
          />
          <div class="contact__details">
            <p><span>Téléphone</span><a href={site.phoneHref}>{site.phoneDisplay}</a></p>
            <p><span>Email</span><a href={`mailto:${site.email}`}>{site.email}</a></p>
            <p><span>Adresse</span><strong>{site.addressStreet}, {site.addressLocality}</strong></p>
          </div>
        </div>
        <ContactForm action={site.formspreeUrl} calUrl={site.calUrl} />
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-4); }
  .products { background: var(--color-surface); }

  .promise__grid { display: grid; grid-template-columns: minmax(0,.8fr) minmax(0,1.2fr); gap: clamp(2.5rem,7vw,7rem); align-items: center; }
  .promise__intro h2 { max-width: 13ch; margin: 0; color: var(--color-brand-ink); font-size: var(--font-size-h2); line-height: var(--line-height-heading); letter-spacing: var(--letter-spacing-heading); }
  .promise__intro p:not(.eyebrow) { max-width: 40rem; color: var(--color-text-soft); }
  .promise__steps { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: 1px; margin: 0; padding: 1px; background: var(--color-border); border: 1px solid var(--color-border); border-radius: var(--radius-panel); overflow: hidden; list-style: none; }
  .promise__steps li { min-height: 10rem; display: grid; align-content: start; gap: var(--space-2); padding: var(--space-6); background: white; }
  .promise__steps span { color: var(--color-gold-dark); font-size: var(--font-size-xs); font-weight: var(--font-weight-heading); }
  .promise__steps strong { color: var(--color-brand-deep); font-size: var(--font-size-h4); }
  .promise__steps small { color: var(--color-text-soft); font-size: var(--font-size-sm); line-height: 1.45; }

  .offer-overview__grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: var(--space-6); }
  .offer-overview article { min-height: 22rem; display: flex; flex-direction: column; align-items: flex-start; padding: clamp(1.75rem,4vw,3.25rem); background: var(--color-page-soft); border: 1px solid var(--color-border); border-radius: var(--radius-panel); }
  .offer-overview__sector { color: var(--color-text-on-dark); background: var(--color-brand-deep) !important; border-color: var(--color-brand-deep) !important; }
  .offer-overview__label { color: var(--color-gold-dark); font-size: var(--font-size-xs); font-weight: var(--font-weight-heading); letter-spacing: .1em; text-transform: uppercase; }
  .offer-overview__sector .offer-overview__label { color: var(--color-gold-soft); }
  .offer-overview h3 { max-width: 18ch; margin: var(--space-5) 0 var(--space-4); color: var(--color-brand-ink); font-size: var(--font-size-h3); line-height: 1.15; }
  .offer-overview__sector h3 { color: white; }
  .offer-overview p { max-width: 38rem; margin: 0 0 auto; color: var(--color-text-soft); }
  .offer-overview__sector p { color: var(--color-text-on-dark-soft); }
  .offer-overview .link-arrow { margin-top: var(--space-8); }
  .offer-overview__links { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-8); }
  .offer-overview__links a { min-height: 2.75rem; display: inline-flex; align-items: center; gap: var(--space-2); padding: .5rem .85rem; color: white; border: 1px solid rgba(255,255,255,.24); border-radius: var(--radius-pill); font-size: var(--font-size-sm); font-weight: var(--font-weight-strong); text-decoration: none; }

  .cabinet-home { background: radial-gradient(circle at 16% 30%, rgba(201,154,70,.13), transparent 23%), var(--color-surface); }
  .cabinet-home__grid { display: grid; grid-template-columns: minmax(17rem,.55fr) minmax(0,1.15fr); gap: clamp(2.5rem,8vw,8rem); align-items: center; }
  .cabinet-home__place { position: relative; min-height: 20rem; display: grid; align-content: center; justify-items: center; overflow: hidden; color: white; background: var(--color-brand-ink); border-radius: 50% 50% var(--radius-panel) var(--radius-panel); box-shadow: var(--shadow-panel); }
  .cabinet-home__place::before { position: absolute; inset: 13%; content: ''; border: 1px solid rgba(201,154,70,.45); border-radius: 50%; }
  .cabinet-home__place span { color: var(--color-gold-soft); font-size: var(--font-size-xs); font-weight: var(--font-weight-heading); letter-spacing: .28em; }
  .cabinet-home__place strong { font-size: 5rem; line-height: .95; }
  .cabinet-home__place small { color: var(--color-text-on-dark-soft); }
  .cabinet-home__copy { max-width: 46rem; }
  .cabinet-home__copy h2 { max-width: 15ch; margin: 0; color: var(--color-brand-ink); font-size: var(--font-size-h2); line-height: var(--line-height-heading); letter-spacing: var(--letter-spacing-heading); }
  .cabinet-home__copy p:not(.eyebrow) { color: var(--color-text-soft); }
  .cabinet-home__copy ul { display: flex; flex-wrap: wrap; gap: var(--space-2); margin: var(--space-6) 0; padding: 0; list-style: none; }
  .cabinet-home__copy li { padding: .5rem .8rem; color: var(--color-brand-deep); background: var(--color-page); border-radius: var(--radius-pill); font-size: var(--font-size-sm); font-weight: var(--font-weight-strong); }

  .article-grid { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: var(--space-5); }
  .faq-layout { max-width: 58rem; }

  .contact { color: var(--color-text-on-dark); background: linear-gradient(135deg,var(--color-brand-ink),var(--color-brand-deep)); }
  .contact__grid { display: grid; grid-template-columns: minmax(0,.78fr) minmax(0,1.22fr); gap: clamp(2.5rem,7vw,7rem); align-items: start; }
  .contact__intro { position: sticky; top: var(--space-8); }
  .contact__details { display: grid; gap: var(--space-4); margin-top: var(--space-8); }
  .contact__details p { display: grid; gap: .2rem; margin: 0; }
  .contact__details span { color: var(--color-gold-soft); font-size: var(--font-size-xs); font-weight: var(--font-weight-heading); letter-spacing: .08em; text-transform: uppercase; }
  .contact__details a, .contact__details strong { min-height: 2.75rem; display: inline-flex; align-items: center; width: fit-content; color: white; font-size: var(--font-size-body-lg); text-decoration: none; }

  @media (max-width: 980px) {
    .promise__grid, .cabinet-home__grid, .contact__grid { grid-template-columns: 1fr; }
    .contact__intro { position: static; }
  }
  @media (max-width: 760px) {
    .promise__steps, .offer-overview__grid, .article-grid { grid-template-columns: 1fr; }
    .promise__steps li, .offer-overview article { min-height: 0; }
    .cabinet-home__place { min-height: 17rem; }
  }
  @media (max-width: 540px) {
    .hero-actions { flex-direction: column; }
    .hero-actions :global(.button) { width: 100%; }
  }
</style>
