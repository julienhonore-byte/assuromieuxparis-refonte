---
interface Props {
  action: string;
  calUrl: string;
  privacyHref?: string;
}

const { action, calUrl, privacyHref = '#confidentialite' } = Astro.props;
---

<div class="contact-form-shell">
  <form class="contact-form form-grid" {action} method="POST" data-contact-form novalidate>
    <div class="form-field">
      <label for="contact-first-name">Prénom <span aria-hidden="true">*</span></label>
      <input id="contact-first-name" name="prenom" type="text" autocomplete="given-name" required aria-describedby="contact-required" />
    </div>

    <div class="form-field">
      <label for="contact-last-name">Nom <span aria-hidden="true">*</span></label>
      <input id="contact-last-name" name="nom" type="text" autocomplete="family-name" required aria-describedby="contact-required" />
    </div>

    <div class="form-field">
      <label for="contact-company">Entreprise <span aria-hidden="true">*</span></label>
      <input id="contact-company" name="entreprise" type="text" autocomplete="organization" required aria-describedby="contact-required" />
    </div>

    <div class="form-field">
      <label for="contact-email">Email professionnel <span aria-hidden="true">*</span></label>
      <input id="contact-email" name="email" type="email" autocomplete="email" inputmode="email" required aria-describedby="contact-required contact-email-help" />
      <p class="form-help" id="contact-email-help">Exemple : nom@entreprise.fr</p>
    </div>

    <div class="form-field">
      <label for="contact-phone">Téléphone <span aria-hidden="true">*</span></label>
      <input id="contact-phone" name="telephone" type="tel" autocomplete="tel" inputmode="tel" required aria-describedby="contact-required contact-phone-help" />
      <p class="form-help" id="contact-phone-help">Le numéro auquel vous souhaitez être rappelé.</p>
    </div>

    <div class="form-field">
      <label for="contact-priority">Besoin principal</label>
      <select id="contact-priority" name="contrat_prioritaire">
        <option value="">Je souhaite être conseillé</option>
        <option data-product-slug="comparaison-assurances">Comparaison d’assurances</option>
        <option data-product-slug="creation-reprise">Création ou reprise d’entreprise</option>
        <option data-product-slug="evolution-entreprise">Évolution d’entreprise</option>
        <option data-product-slug="rc-professionnelle">RC professionnelle</option>
        <option data-product-slug="multirisque">Multirisque professionnelle</option>
        <option data-product-slug="flotte" data-product-aliases="assurer-flotte-vehicules">Flotte automobile</option>
        <option data-product-slug="assurance-btp-decennale">Assurance décennale / BTP</option>
        <option data-product-slug="activite-transport">Activité de transport</option>
        <option data-product-slug="assurance-transport" data-product-aliases="transport transport-routier convoyage demenagement">Transport / marchandises</option>
        <option data-product-slug="sante-prevoyance">Santé et prévoyance</option>
        <option data-product-slug="protection-dirigeant">Protection du dirigeant</option>
        <option data-product-slug="cyber">Cyberassurance</option>
        <option data-product-slug="audit-assurances-entreprise" data-product-aliases="audit audit-contrats auditer-mes-assurances">Audit de contrats</option>
        <option>Autre besoin</option>
      </select>
    </div>

    <div class="form-field form-field--full">
      <label for="contact-message">Message</label>
      <textarea id="contact-message" name="message" aria-describedby="contact-message-help"></textarea>
      <p class="form-help" id="contact-message-help">Précisez votre contexte ou votre prochaine échéance si vous la connaissez. N'envoyez aucun document confidentiel à cette étape.</p>
    </div>

    <div class="form-field visually-hidden" aria-hidden="true">
      <label for="contact-website">Ne pas remplir ce champ</label>
      <input id="contact-website" name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
    </div>

    <input type="hidden" name="source" value="Accueil Astro Assuromieux Paris" />
    <input type="hidden" name="campagne" value="Audit assurances entreprise" />

    <p class="form-note form-field--full" id="contact-required">Les champs signalés par un astérisque sont obligatoires.</p>
    <p class="form-note form-field--full">Les informations transmises servent uniquement à répondre à votre demande. Consultez notre <a href={privacyHref}>information provisoire sur la confidentialité</a>.</p>

    <p class="form-status" role="status" aria-live="polite" data-form-status hidden></p>
    <button class="button button--primary button--large form-field--full" type="submit" data-form-submit>Envoyer ma demande <span aria-hidden="true">→</span></button>
  </form>

  <div class="contact-form-success" data-form-success hidden>
    <p class="eyebrow">Demande reçue</p>
    <h3 tabindex="-1" data-success-heading>Merci, votre demande a bien été envoyée.</h3>
    <p>Nous reviendrons vers vous pour comprendre votre activité, vos contrats et vos prochaines échéances.</p>
    <a class="button button--gold button--large" href={calUrl} target="_blank" rel="noopener noreferrer">Prendre rendez-vous maintenant <span aria-hidden="true">→</span></a>
  </div>
</div>

<script>
  const forms = document.querySelectorAll<HTMLFormElement>('[data-contact-form]');
  const selectedProductKey = 'assuromieux:selected-product';

  forms.forEach((form) => {
    const submit = form.querySelector<HTMLButtonElement>('[data-form-submit]');
    const status = form.querySelector<HTMLElement>('[data-form-status]');
    const success = form.parentElement?.querySelector<HTMLElement>('[data-form-success]');
    const successHeading = success?.querySelector<HTMLElement>('[data-success-heading]');
    const priority = form.querySelector<HTMLSelectElement>('#contact-priority');
    if (!submit || !status || !success) return;

    if (priority) {
      let requestedProduct = new URLSearchParams(window.location.search).get('besoin');

      if (!requestedProduct) {
        try {
          requestedProduct = window.sessionStorage.getItem(selectedProductKey);
        } catch {
          // Le formulaire reste utilisable lorsque le stockage est indisponible.
        }
      }

      const matchingOption = Array.from(priority.options).find((option) => {
        const aliases = option.dataset.productAliases?.split(' ') ?? [];
        return option.dataset.productSlug === requestedProduct || aliases.includes(requestedProduct ?? '');
      });
      if (matchingOption) priority.value = matchingOption.value;
    }

    const setStatus = (message: string, state: 'error' | 'success' | '') => {
      status.textContent = message;
      status.dataset.state = state;
      status.hidden = message.length === 0;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      setStatus('', '');

      if (!form.checkValidity()) {
        setStatus('Certains champs obligatoires sont incomplets ou invalides. Vérifiez les champs signalés.', 'error');
        form.querySelector<HTMLElement>(':invalid')?.focus();
        return;
      }

      const originalLabel = submit.textContent;
      submit.disabled = true;
      submit.textContent = 'Envoi en cours…';
      setStatus('Envoi de votre demande en cours.', '');

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (!response.ok) throw new Error('Formspree response was not successful.');

        form.hidden = true;
        success.hidden = false;
        successHeading?.focus();
        try {
          window.sessionStorage.removeItem(selectedProductKey);
        } catch {
          // Aucun impact sur la confirmation si le stockage est indisponible.
        }
      } catch {
        setStatus('La demande n’a pas pu être envoyée. Réessayez dans quelques instants ou contactez-nous par téléphone.', 'error');
        submit.disabled = false;
        submit.textContent = originalLabel;
      }
    });
  });
</script>

<style>
  .contact-form-shell {
    padding: clamp(1.25rem, 3vw, 2rem);
    background: var(--color-surface);
    border: 1px solid rgba(217, 227, 238, 0.92);
    border-radius: var(--radius-panel);
    box-shadow: var(--shadow-panel);
  }

  .contact-form {
    margin: 0;
  }

  .form-note a {
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    color: var(--color-brand);
    vertical-align: middle;
  }

  .contact-form-success {
    padding: clamp(1.5rem, 5vw, 3rem);
    text-align: center;
  }

  .contact-form-success :global(.eyebrow) {
    justify-content: center;
  }

  .contact-form-success h3 {
    margin: 0;
    color: var(--color-brand-deep);
    font-size: var(--font-size-h2);
    line-height: var(--line-height-heading);
  }

  .contact-form-success p:not(.eyebrow) {
    max-width: 32rem;
    margin: var(--space-5) auto var(--space-8);
    color: var(--color-text-soft);
  }
</style>
