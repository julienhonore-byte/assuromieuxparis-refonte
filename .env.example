# Valeur par défaut et pour toutes les prévisualisations : indexation bloquée.
PUBLIC_SITE_INDEXABLE=false

# Réserver `true` au contexte Netlify Production après GO signé.
# L'indexation exige simultanément PUBLIC_SITE_INDEXABLE=true et CONTEXT=production.
# Netlify fournit CONTEXT automatiquement ; ne pas le définir manuellement dans
# les Deploy Previews ou les branch deploys.
# Le build n'ouvre alors que les dix routes listées dans le plan d'indexation.
