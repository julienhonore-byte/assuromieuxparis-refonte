---
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';
import PageCTA from '../components/PageCTA.astro';
import PageHero from '../components/PageHero.astro';
import ParisHeroVisual from '../components/ParisHeroVisual.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SolutionMethod from '../components/SolutionMethod.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { organizationSchema, personSchema, site } from '../data/site';
import { breadcrumbSchema, pageUrl } from '../data/seo';

const path = '/cabinet/';
const description = 'Découvrez Assuromieux Paris, cabinet de conseil et de courtage dédié à l’audit, l’optimisation et la sécurisation des assurances des entreprises.';
const faqItems = [
  { question: 'Avec qui échange-t-on au cabinet ?', answer: `Jules HONORE est l’interlocuteur direct du cabinet. Il est joignable au ${site.phoneDisplay} et à l’adresse ${site.email}.` },
  { question: 'Le cabinet intervient-il uniquement à Paris ?', answer: 'Non. L’implantation est parisienne, dans le 8e arrondissement, mais l’accompagnement concerne aussi des entreprises franciliennes et situées ailleurs en France.' },
  { question: 'L’approche est-elle réservée à un secteur ?', answer: 'Non. Le cabinet adopte une vision transversale des assurances professionnelles, complétée par des expertises sectorielles en transport, logistique, BTP et décennale.' },
];
const structuredData = [
  organizationSchema,
  personSchema,
  breadcrumbSchema([{ name: 'Accueil', path: '/' }, { name: 'Le cabinet', path }]),
  { '@context': 'https://schema.org', '@type': 'AboutPage', name: 'Le cabinet Assuromieux Paris', description, url: pageUrl(path), about: { '@id': `${site.canonicalUrl}#organization` } },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqItems.map((item) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })) },
];
---

<SiteLayout title="Le cabinet | Assuromieux Paris" {description} canonical={pageUrl(path)} currentPath={path} {structuredData}>
  <main id="contenu-principal">
    <PageHero
      eyebrow="Assuromieux Paris"
      title="Un cabinet de conseil pour éclairer vos décisions d’assurance."
      lead="Une relation directe, une méthode structurée et un accompagnement adapté aux priorités de l’entreprise."
      breadcrumbs={[{ href: '/', label: 'Accueil' }, { label: 'Le cabinet' }]}
    >
      <CTA href="/audit-assurances-entreprise/" label="Découvrir notre méthode" size="large" />
      <CTA href="/#contact" label="Prendre contact" variant="secondary" size="large" />
      <ParisHeroVisual slot="visual" compact />
    </PageHero>

    <section class="section" aria-labelledby="position-title">
      <div class="container-wide content-grid">
        <div class="content-copy">
          <p class="eyebrow">Le cabinet</p>
          <h2 id="position-title">Comprendre l’entreprise avant de parler produit.</h2>
        </div>
        <div class="content-copy">
          <p>Assuromieux Paris accompagne les entreprises dans l’analyse, la comparaison et l’évolution de leurs assurances professionnelles. L’objectif est de rendre les contrats plus lisibles et les décisions mieux reliées aux risques réels.</p>
          <p>Le cabinet ne se limite pas à un produit. Ses expertises transport, logistique et BTP complètent une approche ouverte aux PME, artisans, services, commerces, professions libérales et dirigeants.</p>
        </div>
      </div>
    </section>

    <section class="section section--surface" aria-labelledby="purpose-title">
      <div class="container-wide content-grid">
        <div class="content-copy">
          <p class="eyebrow">Notre raison d’être</p>
          <h2 id="purpose-title">Pourquoi Assuromieux existe</h2>
        </div>
        <div class="content-copy">
          <p>Les contrats d’assurance des entreprises évoluent souvent moins vite que leur activité.</p>
          <p>Une entreprise recrute, investit, achète des véhicules, développe de nouveaux services, répond à de nouveaux marchés ou change d’organisation. Chacune de ces évolutions peut modifier ses responsabilités et son exposition aux risques.</p>
          <p>Pourtant, les assurances sont encore fréquemment traitées contrat par contrat, principalement au moment du renouvellement.</p>
          <p>Assuromieux Paris est né d’une conviction simple : avant de rechercher un tarif ou une nouvelle offre, il faut comprendre l’entreprise, ses activités, ses engagements et les protections déjà en place.</p>
          <p>Notre rôle consiste à aider le dirigeant à prendre du recul, à identifier les points de vigilance et à coordonner ses assurances autour de la réalité de son entreprise.</p>
        </div>
      </div>
    </section>

    <SolutionMethod title="Une approche conseil en quatre temps." text="Comprendre l’activité, analyser les contrats, consulter lorsque cela apporte une comparaison utile et recommander des arbitrages explicites." />

    <section class="section section--surface" aria-labelledby="engagements-title">
      <div class="container-wide content-grid content-grid--reverse">
        <div class="editorial-panel">
          <h2 id="engagements-title">Nos engagements</h2>
          <ul>
            <li>partir de l’activité et des priorités ;</li>
            <li>expliquer les limites autant que les garanties ;</li>
            <li>documenter les arbitrages importants ;</li>
            <li>ne pas promettre un résultat non maîtrisable ;</li>
            <li>maintenir une relation directe et accessible.</li>
          </ul>
        </div>
        <div class="content-copy">
          <p class="eyebrow">Relation directe</p>
          <h2>Un interlocuteur pour comprendre votre entreprise</h2>
          <p>Jules HONORE accompagne les entreprises dans l’analyse et l’organisation de leurs assurances professionnelles.</p>
          <p>Son rôle n’est pas de proposer immédiatement un contrat standardisé. Il commence par comprendre l’activité, les responsabilités, les moyens humains et matériels, les engagements contractuels et les évolutions de l’entreprise.</p>
          <p>Cette démarche permet ensuite d’identifier les protections à examiner, les éventuelles incohérences et les sujets qui nécessitent une comparaison ou une consultation du marché.</p>
          <p class="cabinet-direct"><strong>Téléphone :</strong> <a href={site.phoneHref}>{site.phoneDisplay}</a><br /><strong>Email :</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="paris-title">
      <div class="container-wide content-grid">
        <div class="content-copy">
          <p class="eyebrow">Paris & France entière</p>
          <h2 id="paris-title">Un ancrage parisien, une intervention nationale.</h2>
          <p>Le cabinet est basé au {site.addressStreet}, {site.addressLocality}. Il accompagne les entreprises parisiennes et franciliennes ainsi que des organisations implantées ailleurs en France.</p>
        </div>
        <div class="cabinet-facts">
          <p><span>Implantation</span><strong>Paris 8e</strong></p>
          <p><span>Périmètre</span><strong>France entière</strong></p>
          <p><span>ORIAS</span><strong>{site.orias}</strong></p>
          <p><span>Relation</span><strong>Interlocuteur direct</strong></p>
        </div>
      </div>
    </section>

    <section class="section section--surface" aria-labelledby="faq-title">
      <div class="container faq-layout">
        <SectionHeader kicker="Questions fréquentes" title="Faire connaissance avec le cabinet." id="faq-title" />
        <FAQ items={faqItems} />
      </div>
    </section>

    <RelatedLinks items={[
      { href: '/audit-assurances-entreprise/', label: 'Notre audit', text: 'Voir comment nous structurons l’analyse.' },
      { href: '/assurances-entreprises/', label: 'Nos assurances', text: 'Découvrir les protections transversales.' },
      { href: '/assurance-transport/', label: 'Expertise transport', text: 'Approfondir une expertise sectorielle du cabinet.' },
      { href: '/assurance-btp-decennale/', label: 'Expertise BTP', text: 'Comprendre la lecture des activités, attestations et contrats.' },
      { href: '/ressources/', label: 'Centre de ressources', text: 'Approfondir les questions avant de décider.' },
    ]} />
    <PageCTA title="Échangeons directement sur vos priorités." text={`Contactez Assuromieux Paris au ${site.phoneDisplay} ou présentez votre besoin depuis le formulaire.`} secondaryHref={`mailto:${site.email}`} secondaryLabel="Écrire au cabinet" />
  </main>
</SiteLayout>

<style>
  .cabinet-facts { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 1px; padding: 1px; background: var(--color-border); border: 1px solid var(--color-border); border-radius: var(--radius-panel); overflow: hidden; }
  .cabinet-facts p { display: grid; gap: var(--space-2); margin: 0; padding: var(--space-6); background: white; }
  .cabinet-facts span { color: var(--color-gold-dark); font-size: var(--font-size-xs); font-weight: var(--font-weight-heading); letter-spacing: .08em; text-transform: uppercase; }
  .cabinet-facts strong { color: var(--color-brand-deep); }
  .cabinet-direct :global(a) { min-height: 2.75rem; display: inline-flex; align-items: center; }
  @media (max-width: 540px) { .cabinet-facts { grid-template-columns: 1fr; } }
</style>
