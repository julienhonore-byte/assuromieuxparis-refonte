---
interface Item { title: string; text: string; }
interface Props { id: string; kicker?: string; title: string; intro: string; items: Item[]; note?: string; tone?: 'light' | 'soft'; }
const { id, kicker = 'À préparer', title, intro, items, note, tone = 'soft' } = Astro.props;
---
<section id={id} class:list={['section','need-checklist',tone === 'soft' && 'section--surface']} aria-labelledby={`${id}-title`}>
  <div class="container-wide">
    <header><div><p class="eyebrow">{kicker}</p><h2 id={`${id}-title`}>{title}</h2></div><p>{intro}</p></header>
    <div class="need-checklist__items">
      {items.map((item) => <article><h3>{item.title}</h3><p>{item.text}</p></article>)}
    </div>
    {note && <p class="need-checklist__note">{note}</p>}
  </div>
</section>
<style>
  header { display: grid; grid-template-columns: minmax(0,1fr) minmax(18rem,.58fr); gap: clamp(2rem,7vw,7rem); align-items: end; margin-bottom: clamp(2.5rem,5vw,4rem); }
  h2 { max-width: 17ch; margin: 0; color: var(--color-brand-ink); font-size: var(--font-size-h2); line-height: var(--line-height-heading); letter-spacing: var(--letter-spacing-heading); }
  header > p { margin: 0; color: var(--color-text-soft); }
  .need-checklist__items { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  article { min-height: 10rem; padding: clamp(1.4rem,3vw,2.25rem); background: var(--color-page); }
  .section--surface article { background: var(--color-surface); }
  h3 { margin: 0; color: var(--color-brand-deep); font-size: var(--font-size-h4); }
  article p { margin: var(--space-3) 0 0; color: var(--color-text-soft); font-size: var(--font-size-sm); }
  .need-checklist__note { max-width: 60rem; margin: var(--space-6) 0 0; padding: var(--space-5) var(--space-6); color: var(--color-brand-deep); background: var(--color-gold-wash); border-left: 4px solid var(--color-gold); }
  @media (max-width: 760px) { header, .need-checklist__items { grid-template-columns: 1fr; } }
</style>
