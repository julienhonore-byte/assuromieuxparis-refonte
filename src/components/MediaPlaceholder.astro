---
interface Props {
  label: string;
  alt: string;
  kind?: 'portrait' | 'place' | 'sector';
  note?: string;
}

const { label, alt, kind = 'place', note = 'Visuel original à produire' } = Astro.props;
---

<figure class:list={['media-placeholder', `media-placeholder--${kind}`]} role="img" aria-label={alt}>
  <div class="media-placeholder__shape" aria-hidden="true"><span></span></div>
  <figcaption>
    <strong>{label}</strong>
    <span>{note}</span>
  </figcaption>
</figure>

<style>
  .media-placeholder {
    position: relative;
    min-height: 27rem;
    display: flex;
    align-items: flex-end;
    margin: 0;
    overflow: hidden;
    background:
      radial-gradient(circle at 68% 18%, rgba(201, 154, 70, 0.24), transparent 23%),
      linear-gradient(145deg, #e7f0f8, #f8fbfe);
    border: 1px solid var(--color-border);
    border-radius: 46% 46% var(--radius-panel) var(--radius-panel) / 32% 32% var(--radius-panel) var(--radius-panel);
    box-shadow: var(--shadow-panel);
  }

  .media-placeholder--portrait { min-height: 35rem; }
  .media-placeholder--sector { min-height: 22rem; border-radius: var(--radius-panel) 45% var(--radius-panel) 45%; }

  .media-placeholder__shape {
    position: absolute;
    inset: 13% 19% 18%;
    border: 1px solid rgba(18, 54, 95, 0.18);
    border-radius: 48% 48% 34% 34%;
  }

  .media-placeholder__shape::before,
  .media-placeholder__shape::after {
    position: absolute;
    content: '';
    border-radius: 50%;
  }

  .media-placeholder__shape::before {
    width: 42%;
    aspect-ratio: 1;
    top: 8%;
    left: 29%;
    background: rgba(18, 54, 95, 0.12);
  }

  .media-placeholder__shape::after {
    width: 78%;
    height: 45%;
    right: 11%;
    bottom: 0;
    background: rgba(18, 54, 95, 0.1);
    border-radius: 50% 50% 24% 24%;
  }

  figcaption {
    position: relative;
    z-index: 1;
    width: calc(100% - 2rem);
    display: grid;
    gap: 0.1rem;
    margin: var(--space-4);
    padding: var(--space-4);
    color: var(--color-surface);
    background: rgba(7, 28, 51, 0.9);
    border-radius: var(--radius-card-sm);
    backdrop-filter: blur(10px);
  }

  figcaption strong { font-size: var(--font-size-sm); }
  figcaption span { color: var(--color-text-on-dark-soft); font-size: var(--font-size-xs); }

  @media (max-width: 640px) {
    .media-placeholder,
    .media-placeholder--portrait { min-height: 24rem; }
  }
</style>
