---
interface Heading { depth: number; slug: string; text: string; }
interface Props { headings: Heading[]; }
const { headings } = Astro.props;
const items = headings.filter((heading) => heading.depth === 2);
---
{items.length > 0 && <nav class="resource-toc" aria-label="Sommaire du guide">
  <p>Dans ce guide</p>
  <ol>{items.map((heading) => <li><a href={`#${heading.slug}`}>{heading.text}</a></li>)}</ol>
</nav>}
<style>
  .resource-toc { position: sticky; top: var(--space-6); padding: var(--space-6); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-card-sm); }
  p { margin: 0 0 var(--space-4); color: var(--color-brand-deep); font-size: var(--font-size-sm); font-weight: var(--font-weight-heading); }
  ol { display: grid; gap: var(--space-2); margin: 0; padding: 0; list-style: none; counter-reset: toc; }
  li { counter-increment: toc; }
  a { min-height: 2.75rem; display: flex; align-items: center; gap: var(--space-3); color: var(--color-text-soft); font-size: var(--font-size-sm); text-decoration: none; }
  a::before { content: counter(toc, decimal-leading-zero); color: var(--color-gold-dark); font-size: var(--font-size-xs); font-weight: var(--font-weight-heading); }
  a:hover { color: var(--color-brand); text-decoration: underline; }
  @media (max-width: 980px) { .resource-toc { position: static; } }
</style>
