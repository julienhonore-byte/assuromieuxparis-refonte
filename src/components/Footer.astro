---
import type { NavigationItem } from '../data/site';

interface Props {
  phoneDisplay: string;
  phoneHref: string;
  email: string;
  addressStreet: string;
  addressLocality: string;
  addressCountry: string;
  orias: string;
  rcs: string;
  productLinks: NavigationItem[];
  adviceLinks: NavigationItem[];
  auditHref?: string;
}

const {
  phoneDisplay,
  phoneHref,
  email,
  addressStreet,
  addressLocality,
  addressCountry,
  orias,
  rcs,
  productLinks,
  adviceLinks,
  auditHref = '/audit-assurances-entreprise/',
} = Astro.props;

const year = new Date().getFullYear();
---

<!-- TODO conformité : vérifier avant publication ORIAS, RCS, adresse et formulation L521-2.II.b. -->
<footer class="site-footer">
  <div class="container-wide">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <img src="/logo/assuromieux-paris.jpeg" width="300" height="83" alt="Assuromieux Paris" />
        <p>Cabinet de courtage et de conseil en assurances d’entreprise, basé à Paris et présent aux côtés des dirigeants partout en France.</p>
        <a class="site-footer__audit" href={auditHref}>Demander un audit gratuit <span aria-hidden="true">→</span></a>
      </div>

      <nav aria-label="Assurances">
        <h2>Assurances</h2>
        {productLinks.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>

      <nav aria-label="Conseil et expertises">
        <h2>Conseil &amp; expertises</h2>
        {adviceLinks.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>

      <div class="site-footer__contact">
        <h2>Nous contacter</h2>
        <address>
          <span>{addressStreet}</span>
          <span>{addressLocality}</span>
          <span>{addressCountry}</span>
        </address>
        <a href={phoneHref}>{phoneDisplay}</a>
        <a href={`mailto:${email}`}>{email}</a>
        <a href="https://orias.fr" target="_blank" rel="noopener noreferrer">ORIAS {orias}</a>
      </div>
    </div>

    <div class="site-footer__legal">
      <div id="mentions-legales">
        <strong>Informations réglementaires</strong>
        <p>ASSUROMIEUX PARIS, dont le siège est situé 60 Rue Francois 1er 75008 Paris (France), immatriculée au Registre du Commerce et des Sociétés de Paris sous le numéro {rcs}. Inscrite à l’ORIAS sous le numéro {orias}. Exerce son activité en application des dispositions de l’article L521-2.II.b du Code des Assurances.</p>
      </div>
      <div id="confidentialite">
        <strong>Confidentialité</strong>
        <p>Information provisoire : les données du formulaire sont utilisées pour répondre à la demande et transmises via Formspree. La politique complète reste à valider avant publication.</p>
      </div>
    </div>

    <div class="site-footer__bottom">
      <p>© {year} Assuromieux Paris. Tous droits réservés.</p>
      <div>
        <a href="#mentions-legales">Mentions légales</a>
        <a href="#confidentialite">Politique de confidentialité</a>
        <span>Validation réglementaire requise avant publication</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding-block: clamp(4.5rem, 8vw, 7rem) var(--space-6);
    color: var(--color-text-on-dark-soft);
    background:
      radial-gradient(circle at 8% 4%, rgba(201, 154, 70, 0.14), transparent 22%),
      var(--color-brand-ink);
    font-size: var(--font-size-sm);
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: 1.45fr 0.85fr 0.85fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    padding-bottom: var(--space-16);
    border-bottom: 1px solid rgba(217, 227, 238, 0.16);
  }

  .site-footer__brand img {
    width: 10.75rem;
    height: auto;
    margin-bottom: var(--space-5);
  }

  .site-footer__brand p {
    max-width: 25rem;
    margin: 0 0 var(--space-6);
    font-size: 0.9375rem;
  }

  h2,
  strong {
    display: block;
    margin: 0 0 var(--space-4);
    color: var(--color-surface);
    font-size: 0.875rem;
    font-weight: var(--font-weight-heading);
    letter-spacing: 0.04em;
  }

  nav,
  .site-footer__contact,
  address {
    display: grid;
    align-content: start;
    gap: var(--space-2);
  }

  address {
    margin-bottom: var(--space-2);
    font-style: normal;
  }

  a {
    min-height: 2rem;
    display: inline-flex;
    align-items: center;
    width: fit-content;
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    color: var(--color-gold-soft);
    text-decoration: underline;
  }

  .site-footer__audit {
    min-height: 2.75rem;
    padding-inline: var(--space-4);
    color: var(--color-brand-ink);
    background: var(--color-gold-soft);
    border-radius: var(--radius-pill);
    font-weight: var(--font-weight-strong);
    text-decoration: none !important;
  }

  .site-footer__legal {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-8);
    padding-block: var(--space-8);
    border-bottom: 1px solid rgba(217, 227, 238, 0.16);
  }

  .site-footer__legal p,
  .site-footer__bottom p {
    margin: 0;
    font-size: var(--font-size-xs);
    line-height: 1.65;
  }

  .site-footer__bottom,
  .site-footer__bottom div {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .site-footer__bottom {
    justify-content: space-between;
    padding-top: var(--space-6);
  }

  .site-footer__bottom span {
    color: var(--color-gold-soft);
    font-size: var(--font-size-xs);
  }

  @media (max-width: 980px) {
    .site-footer__top {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    a {
      min-height: 2.75rem;
    }
  }

  @media (max-width: 640px) {
    .site-footer {
      padding-bottom: 6.5rem;
    }

    .site-footer__top,
    .site-footer__legal {
      grid-template-columns: 1fr;
    }

    .site-footer__bottom,
    .site-footer__bottom div {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-2);
    }

  }
</style>
