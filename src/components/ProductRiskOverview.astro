---
interface RiskItem {
  title: string;
  text: string;
}

interface Props {
  title: string;
  intro: string;
  items: RiskItem[];
  distinction?: string;
  variant?: 'ledger' | 'columns' | 'flow';
}

const { title, intro, items, distinction, variant = 'ledger' } = Astro.props;
---

<section id="risques" class:list={['section', 'section--surface', 'product-risks', `product-risks--${variant}`]} aria-labelledby="risks-title">
  <div class="container-wide">
    <header class="product-risks__header">
      <div>
        <p class="eyebrow">Situations et risques concernés</p>
        <h2 id="risks-title">{title}</h2>
      </div>
      <p>{intro}</p>
    </header>

    <ol class="product-risks__items">
      {items.map((item, index) => (
        <li>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <div><h3>{item.title}</h3><p>{item.text}</p></div>
        </li>
      ))}
    </ol>

    {distinction && <p class="product-risks__distinction">{distinction}</p>}
  </div>
</section>

<style>
  .product-risks__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.56fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: end;
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .product-risks__header h2 {
    max-width: 18ch;
    margin: 0;
    color: var(--color-brand-ink);
    font-size: var(--font-size-h2);
    letter-spacing: var(--letter-spacing-heading);
    line-height: var(--line-height-heading);
  }

  .product-risks__header > p {
    margin: 0;
    color: var(--color-text-soft);
  }

  .product-risks__items {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .product-risks__items li {
    min-width: 0;
  }

  .product-risks__items span {
    color: var(--color-gold-dark);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-heading);
    letter-spacing: 0.08em;
  }

  .product-risks__items h3 {
    margin: 0;
    color: var(--color-brand-deep);
    font-size: var(--font-size-h4);
    line-height: 1.25;
  }

  .product-risks__items p {
    margin: var(--space-2) 0 0;
    color: var(--color-text-soft);
    font-size: var(--font-size-sm);
  }

  .product-risks--ledger .product-risks__items {
    border-top: 1px solid var(--color-border);
  }

  .product-risks--ledger .product-risks__items li {
    display: grid;
    grid-template-columns: 3rem minmax(12rem, 0.62fr) minmax(0, 1.38fr);
    gap: var(--space-5);
    align-items: baseline;
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .product-risks--ledger .product-risks__items li div {
    display: contents;
  }

  .product-risks--columns .product-risks__items {
    columns: 2;
    column-gap: clamp(2rem, 6vw, 6rem);
  }

  .product-risks--columns .product-risks__items li {
    break-inside: avoid;
    display: grid;
    grid-template-columns: 2.25rem minmax(0, 1fr);
    gap: var(--space-4);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--color-border);
  }

  .product-risks--flow .product-risks__items {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1.5rem, 3vw, 3rem);
  }

  .product-risks--flow .product-risks__items::before {
    position: absolute;
    top: 1.05rem;
    right: 0;
    left: 0;
    height: 1px;
    content: '';
    background: linear-gradient(90deg, var(--color-gold), var(--color-border));
  }

  .product-risks--flow .product-risks__items li {
    position: relative;
    z-index: 1;
    padding-top: 3rem;
  }

  .product-risks--flow .product-risks__items span {
    position: absolute;
    top: 0;
    left: 0;
    width: 2.15rem;
    height: 2.15rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    border: 1px solid var(--color-gold);
    border-radius: 50%;
  }

  .product-risks__distinction {
    max-width: 58rem;
    margin: var(--space-8) 0 0;
    padding: var(--space-5) var(--space-6);
    color: var(--color-brand-deep);
    background: var(--color-gold-wash);
    border-left: 4px solid var(--color-gold);
    font-weight: var(--font-weight-medium);
  }

  @media (max-width: 860px) {
    .product-risks__header {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .product-risks--flow .product-risks__items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-8) var(--space-5);
    }

    .product-risks--flow .product-risks__items::before {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .product-risks--columns .product-risks__items {
      columns: 1;
    }

    .product-risks--ledger .product-risks__items li {
      grid-template-columns: 2rem minmax(0, 1fr);
    }

    .product-risks--ledger .product-risks__items li div {
      display: block;
    }

    .product-risks--ledger .product-risks__items p {
      margin-top: var(--space-2);
    }

    .product-risks--flow .product-risks__items {
      grid-template-columns: 1fr;
    }
  }
</style>
