---
import type { NavigationItem } from '../data/site';

interface Props {
  items: NavigationItem[];
  currentPath?: string;
}

const { items, currentPath = '/' } = Astro.props;

const isCurrent = (href: string) => !href.includes('#') && href === currentPath;
---

<nav class="desktop-nav" aria-label="Navigation principale">
  {items.map((item) => (
    <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
  ))}
</nav>

<style>
  .desktop-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.85rem, 1.45vw, 1.5rem);
    color: var(--color-text-strong);
    font-size: 0.8125rem;
    font-weight: var(--font-weight-strong);
  }

  a {
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    position: relative;
    text-decoration: none;
    white-space: nowrap;
  }

  a::after {
    position: absolute;
    right: 0;
    bottom: 0.35rem;
    left: 0;
    height: 2px;
    content: '';
    background: var(--color-gold);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--transition-base);
  }

  a:hover,
  a[aria-current='page'] {
    color: var(--color-brand-deep);
  }

  a:hover::after,
  a[aria-current='page']::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  @media (max-width: 980px) {
    .desktop-nav {
      display: none;
    }
  }
</style>
