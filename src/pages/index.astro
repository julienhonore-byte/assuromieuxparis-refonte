---
import ArticleCard from '../components/ArticleCard.astro';
import Card from '../components/Card.astro';
import ContactForm from '../components/ContactForm.astro';
import CTA from '../components/CTA.astro';
import ExpertiseCard from '../components/ExpertiseCard.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import MethodStep from '../components/MethodStep.astro';
import SectionHeader from '../components/SectionHeader.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import TrustBadge from '../components/TrustBadge.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  footerExpertiseLinks,
  footerSectorLinks,
  mainNavigation,
  site,
} from '../data/site';

const expertises = [
  { code: '01', title: 'Assurance transport', text: 'Responsabilités du transporteur, exploitation et engagements contractuels sont analysés comme un ensemble.', futureHref: '/assurance-transport' },
  { code: '02', title: 'Flotte automobile', text: 'Une lecture du parc, des usages, de la sinistralité et des franchises pour ajuster réellement le contrat.', futureHref: '/assurance-flotte-automobile' },
  { code: '03', title: 'TPM et marchandises transportées', text: 'Des garanties cohérentes avec les flux, les valeurs confiées, le stockage et la sous-traitance.', futureHref: '/assurance-marchandises-transportees' },
  { code: '04', title: 'RC professionnelle', text: 'Une couverture calibrée sur les prestations, les obligations et les dommages susceptibles d’engager l’entreprise.', futureHref: '/rc-professionnelle' },
  { code: '05', title: 'Multirisque professionnelle', text: 'Locaux, matériels, pertes d’exploitation et responsabilités étudiés sans empiler des garanties inutiles.', futureHref: '/multirisque-professionnelle' },
  { code: '06', title: 'Assurance décennale et BTP', text: 'Activités déclarées, procédés, sous-traitance et attestations sécurisés au regard des chantiers réellement réalisés.', futureHref: '/assurance-btp-decennale', id: 'expertise-btp' },
  { code: '07', title: 'Santé et prévoyance entreprise', text: 'Des régimes collectifs lisibles, adaptés aux équipes et aux obligations de l’employeur.', futureHref: '/sante-prevoyance-entreprise' },
  { code: '08', title: 'Protection du dirigeant', text: 'Un dispositif pensé pour la continuité de l’activité et la protection personnelle du décideur.', futureHref: '/protection-dirigeant' },
  { code: '09', title: 'Cyberassurance', text: 'Prévention, assistance et transfert du risque numérique selon l’exposition concrète de l’organisation.', futureHref: '/cyberassurance' },
];

const faqItems = [
  { question: 'Comment se déroule l’audit de mes assurances ?', answer: 'Nous échangeons d’abord sur votre activité, vos risques et vos échéances. Après lecture des contrats disponibles, nous identifions les incohérences, les doublons et les garanties à consolider, puis nous présentons une recommandation argumentée.' },
  { question: 'Quels documents faut-il prévoir ?', answer: 'Selon le besoin : contrats et avenants, appels de cotisation, état du parc, relevés de sinistralité, chiffre d’affaires par activité et documents décrivant vos obligations. Nous précisons la liste utile après le premier échange.' },
  { question: 'L’analyse est-elle payante ?', answer: 'La première analyse proposée depuis cette page est sans engagement. Le périmètre et les éventuelles conditions d’un accompagnement ultérieur sont expliqués avant toute démarche.' },
  { question: 'Combien de temps faut-il prévoir ?', answer: 'Le délai dépend du nombre de contrats, de la qualité des informations disponibles et de la consultation éventuelle du marché. Un calendrier réaliste est fixé dès que le périmètre est connu.' },
  { question: 'Puis-je conserver mon assureur actuel ?', answer: 'Oui. L’audit peut conclure qu’un contrat doit être ajusté plutôt que remplacé. La recommandation repose sur la qualité globale de la couverture, pas sur le changement pour lui-même.' },
  { question: 'Comment changer de courtier ?', answer: 'La marche à suivre dépend des contrats, des mandats existants et des échéances. Nous vérifions ces éléments avant de proposer une transition, afin d’éviter toute rupture de couverture.' },
  { question: 'Intervenez-vous en dehors de Paris ?', answer: 'Oui. Le cabinet est basé à Paris et accompagne aussi des entreprises partout en France, avec des échanges à distance et des rendez-vous adaptés au contexte.' },
  { question: 'Quels secteurs accompagnez-vous ?', answer: 'Nous intervenons auprès des PME, artisans, sociétés de services, commerces, professions libérales et dirigeants, avec une expertise particulièrement développée en transport et logistique.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${site.canonicalUrl}#organization`,
    name: site.name,
    legalName: site.legalName,
    url: site.canonicalUrl,
    logo: `${site.canonicalUrl}logo/assuromieux-paris.jpeg`,
    email: site.email,
    telephone: '+33695699674',
    address: {
      '@type': 'PostalAddress',
      streetAddress: site.addressStreet,
      postalCode: '75008',
      addressLocality: 'Paris',
      addressCountry: 'FR',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': ['LocalBusiness', 'InsuranceAgency'],
    '@id': `${site.canonicalUrl}#insurance-agency`,
    name: site.name,
    url: site.canonicalUrl,
    image: `${site.canonicalUrl}og.jpg`,
    telephone: '+33695699674',
    email: site.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: site.addressStreet,
      postalCode: '75008',
      addressLocality: 'Paris',
      addressCountry: 'FR',
    },
    areaServed: { '@type': 'Country', name: 'France' },
    parentOrganization: { '@id': `${site.canonicalUrl}#organization` },
  },
];
---

<BaseLayout
  title="Courtier en assurance entreprise à Paris | Assuromieux Paris"
  description="Assuromieux Paris accompagne les entreprises dans l’audit, l’optimisation et le courtage de leurs assurances, avec une expertise transport et logistique."
  canonical={site.canonicalUrl}
  image={`${site.canonicalUrl}og.jpg`}
  structuredData={structuredData}
>
  <Header
    items={mainNavigation}
    phoneDisplay={site.phoneDisplay}
    phoneHref={site.phoneHref}
    email={site.email}
    orias={site.orias}
  />

  <main id="contenu-principal">
    <Hero
      eyebrow="Courtage & conseil en assurances d’entreprise"
      title="Vos assurances d’entreprise méritent mieux qu’un simple renouvellement."
      lead="Assuromieux Paris analyse, compare et optimise vos contrats pour protéger votre activité, maîtriser vos coûts et sécuriser vos garanties."
    >
      <div class="hero-actions">
        <CTA href="#contact" label="Demander mon audit gratuit" size="large" />
        <CTA href="#methode" label="Découvrir notre méthode" variant="secondary" size="large" />
      </div>
      <ul class="hero-cues" aria-label="Points clés">
        <li>Paris & France entière</li>
        <li>Entreprises</li>
        <li>Transport & logistique</li>
      </ul>

      <div slot="visual" class="risk-map" aria-hidden="true">
        <div class="risk-map__orbit risk-map__orbit--one"></div>
        <div class="risk-map__orbit risk-map__orbit--two"></div>
        <div class="risk-map__core">
          <span>AUDIT</span>
          <strong>Votre activité</strong>
          <small>au centre de l’analyse</small>
        </div>
        <div class="risk-map__item risk-map__item--one"><span>01</span> Contrats</div>
        <div class="risk-map__item risk-map__item--two"><span>02</span> Risques</div>
        <div class="risk-map__item risk-map__item--three"><span>03</span> Marché</div>
        <div class="risk-map__item risk-map__item--four"><span>04</span> Suivi</div>
        <div class="risk-map__seal">Conseil<br />sur mesure</div>
      </div>
    </Hero>

    <section class="trust-strip" aria-label="Nos engagements">
      <div class="container-wide trust-grid">
        <TrustBadge label="Analyse sans engagement" />
        <TrustBadge label="Accès à plusieurs compagnies" />
        <TrustBadge label="Approche indépendante" />
        <TrustBadge label="Accompagnement personnalisé" />
        <TrustBadge label="Expertise sectorielle" />
      </div>
    </section>

    <section class="section section--surface problems" aria-labelledby="problemes-title">
      <div class="container-wide split-heading">
        <SectionHeader kicker="Le constat" title="Un contrat peut rester en place longtemps après avoir cessé d’être juste." id="problemes-title" />
        <p>Une assurance utile suit l’entreprise : son activité, ses clients, ses actifs, ses équipes et ses obligations. Quand ce lien se distend, le renouvellement automatique devient un risque en soi.</p>
      </div>
      <div class="container-wide problem-grid">
        <Card overline="Budget" title="Des primes qui progressent" text="Les hausses s’accumulent sans toujours être reliées à l’évolution réelle du risque." />
        <Card overline="Lisibilité" title="Des garanties difficiles à arbitrer" text="Plafonds, franchises et exclusions rendent les comparaisons superficielles trompeuses." />
        <Card overline="Évolution" title="Des contrats devenus inadaptés" text="Une nouvelle activité ou un client exigeant peut modifier l’exposition sans modifier le contrat." />
        <Card overline="Pilotage" title="Une couverture fragmentée" text="Plusieurs contrats, interlocuteurs et échéances peuvent créer doublons et zones grises." />
        <Card overline="Temps" title="Un marché peu consulté" text="Les équipes manquent souvent de temps pour documenter le risque et mettre les offres en concurrence." />
        <Card overline="Exclusions" title="Des limites découvertes trop tard" text="Une exclusion mal identifiée prend toute son importance au moment du sinistre." />
      </div>
    </section>

    <section id="expertises" class="section" aria-labelledby="expertises-title">
      <div class="container-wide">
        <SectionHeader
          kicker="Domaines d’expertise"
          title="Une vision d’ensemble, contrat par contrat."
          text="Nous relions chaque police au fonctionnement concret de l’entreprise pour construire une couverture cohérente, lisible et défendable."
          id="expertises-title"
        />
        <div class="expertise-grid">
          {expertises.map((expertise) => <ExpertiseCard {...expertise} />)}
        </div>
      </div>
    </section>

    <section id="methode" class="section method" aria-labelledby="methode-title">
      <div class="container-wide method__grid">
        <div class="method__intro">
          <SectionHeader
            kicker="L’audit Assuromieux"
            title="Comprendre d’abord. Recommander ensuite."
            text="Notre méthode transforme des documents techniques en décisions de direction : ce qui protège, ce qui manque, ce qui se négocie et ce qui doit être suivi."
            tone="dark"
            id="methode-title"
          />
          <CTA href="#contact" label="Lancer l’analyse" variant="gold" size="large" />
        </div>
        <div class="method__steps">
          <MethodStep step="01" title="Analyse" text="Comprendre l’activité, les contrats, les obligations et les échéances." />
          <MethodStep step="02" title="Diagnostic" text="Repérer incohérences, doublons, exclusions sensibles et marges d’amélioration." />
          <MethodStep step="03" title="Consultation du marché" text="Interroger les solutions pertinentes sur la base d’un risque correctement présenté." />
          <MethodStep step="04" title="Négociation" text="Travailler garanties, franchises, conditions et tarification dans leur ensemble." />
          <MethodStep step="05" title="Recommandation" text="Comparer clairement les scénarios et expliciter les arbitrages proposés." />
          <MethodStep step="06" title="Suivi" text="Faire évoluer le dispositif avec l’entreprise et ses prochains enjeux." />
        </div>
      </div>
    </section>

    <section id="transport-logistique" class="section transport" aria-labelledby="transport-title">
      <div class="container-wide transport__grid">
        <div>
          <SectionHeader
            kicker="Transport & logistique"
            title="Les risques circulent. Leur couverture doit suivre."
            text="Transporteurs routiers, logisticiens, entrepôts, convoyeurs, déménageurs et commissionnaires font face à des responsabilités imbriquées. Nous les lisons comme une chaîne complète."
            id="transport-title"
          />
          <div class="transport__professions">
            {['Flottes poids lourds', 'VUL & convoyage', 'Entrepôts', 'Déménagement', 'Commissionnaires', 'Marchandises transportées'].map((item) => <span>{item}</span>)}
          </div>
        </div>
        <div class="transport__panel">
          <p class="eyebrow">Lecture sectorielle</p>
          <h3>Huit dimensions à mettre en cohérence</h3>
          <ol>
            {['Responsabilités', 'Véhicules', 'Marchandises', 'Sous-traitance', 'Sinistralité', 'Donneurs d’ordre', 'Exploitation', 'Stockage'].map((item, index) => <li><span>{String(index + 1).padStart(2, '0')}</span>{item}</li>)}
          </ol>
        </div>
      </div>
    </section>

    <section id="assurances-entreprises" class="section section--surface enterprise" aria-labelledby="entreprises-title">
      <div class="container-wide">
        <SectionHeader
          kicker="Assurances entreprises"
          title="Le conseil ne s’arrête pas au transport."
          text="Assuromieux Paris accompagne aussi les organisations qui veulent reprendre la maîtrise de leur programme d’assurances, quel que soit leur secteur."
          id="entreprises-title"
        />
        <div class="audience-grid">
          {['PME', 'Artisans', 'Entreprises de services', 'Commerces', 'Professions libérales', 'Dirigeants'].map((item, index) => (
            <div class="audience-card"><span>{String(index + 1).padStart(2, '0')}</span><strong>{item}</strong></div>
          ))}
        </div>
      </div>
    </section>

    <section id="paris" class="section paris" aria-labelledby="paris-title">
      <div class="container-wide paris__grid">
        <div class="paris__marker" aria-hidden="true"><span>75</span><small>Paris</small></div>
        <div>
          <SectionHeader
            kicker="Un cabinet parisien, une portée nationale"
            title="La proximité d’un interlocuteur, l’amplitude d’un réseau."
            text="Basé dans le 8e arrondissement, Assuromieux Paris accompagne les entreprises parisiennes et franciliennes tout en intervenant partout en France. Les échanges restent directs, disponibles et adaptés au rythme des dirigeants."
            id="paris-title"
          />
          <a class="text-link" href="#contact">Échanger sur votre situation <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <section class="section cases" aria-labelledby="cas-title">
      <div class="container-wide">
        <SectionHeader kicker="Cas pratiques" title="De la situation subie à la décision éclairée." text="Ces scénarios illustrent notre manière de raisonner. Ils ne constituent ni une promesse de résultat ni des références clients." id="cas-title" />
        <div class="case-grid">
          <Card overline="Transport" title="Une flotte devenue difficile à piloter" tone="soft">
            <dl><div><dt>Situation</dt><dd>Parc hétérogène et sinistralité répartie sur plusieurs usages.</dd></div><div><dt>Risque identifié</dt><dd>Franchises et garanties mal alignées avec l’exploitation.</dd></div><div><dt>Accompagnement</dt><dd>Lecture du parc, des conducteurs, des sinistres et des contrats.</dd></div><div><dt>Résultat attendu</dt><dd>Une architecture plus lisible et des arbitrages documentés.</dd></div></dl>
          </Card>
          <Card overline="PME" title="Des contrats empilés au fil de la croissance" tone="soft">
            <dl><div><dt>Situation</dt><dd>Plusieurs polices ajoutées sans vision consolidée.</dd></div><div><dt>Risque identifié</dt><dd>Doublons, interstices de garantie et échéances dispersées.</dd></div><div><dt>Accompagnement</dt><dd>Cartographie des contrats et rapprochement avec les risques.</dd></div><div><dt>Résultat attendu</dt><dd>Un programme cohérent, plus simple à suivre et à expliquer.</dd></div></dl>
          </Card>
          <Card overline="BTP" title="Une décennale à sécuriser avant chantier" tone="soft">
            <dl><div><dt>Situation</dt><dd>Une entreprise élargit ses techniques et ses marchés.</dd></div><div><dt>Risque identifié</dt><dd>Écart possible entre activités exercées et activités déclarées.</dd></div><div><dt>Accompagnement</dt><dd>Revue des activités, procédés, attestations et sous-traitants.</dd></div><div><dt>Résultat attendu</dt><dd>Des déclarations mieux alignées avec les travaux envisagés.</dd></div></dl>
          </Card>
        </div>
      </div>
    </section>

    <section id="ressources" class="section section--surface resources" aria-labelledby="ressources-title">
      <div class="container-wide">
        <SectionHeader kicker="Ressources" title="Rendre l’assurance d’entreprise plus intelligible." text="Guides, analyses et retours d’expérience viendront éclairer les décisions avant les échéances et les transformations importantes." id="ressources-title" />
        <div class="article-grid">
          <ArticleCard type="Guide" title="Préparer l’audit de ses assurances d’entreprise" summary="Les documents, questions et points de vigilance à réunir avant une analyse complète." />
          <ArticleCard type="Analyse" title="Flotte automobile : lire au-delà de la prime" summary="Franchises, usages, parc et sinistralité : les variables qui donnent du sens à la comparaison." />
          <ArticleCard type="Décryptage" title="Décennale : vérifier la portée de son attestation" summary="Une méthode de lecture pour rapprocher activités déclarées et chantiers réellement exécutés." />
        </div>
      </div>
    </section>

    <section class="section faq-section" aria-labelledby="faq-title">
      <div class="container faq-layout">
        <SectionHeader kicker="Questions fréquentes" title="Avant de commencer l’analyse." id="faq-title" />
        <FAQ items={faqItems} />
      </div>
    </section>

    <section id="contact" class="section contact" aria-labelledby="contact-title">
      <div class="container-wide contact__grid">
        <div class="contact__intro">
          <SectionHeader
            kicker="Premier échange"
            title="Faisons le point sur ce que vos contrats protègent vraiment."
            text="Décrivez votre activité, le contrat prioritaire et votre prochaine échéance. Nous reviendrons vers vous pour cadrer l’analyse utile."
            tone="dark"
            id="contact-title"
          />
          <div class="contact__details">
            <p><span>Téléphone</span><a href={site.phoneHref}>{site.phoneDisplay}</a></p>
            <p><span>Email</span><a href={`mailto:${site.email}`}>{site.email}</a></p>
            <p><span>Adresse</span><strong>{site.addressStreet}, {site.addressLocality}</strong></p>
          </div>
        </div>
        <ContactForm action={site.formspreeUrl} calUrl={site.calUrl} />
      </div>
    </section>
  </main>

  <Footer
    phoneDisplay={site.phoneDisplay}
    phoneHref={site.phoneHref}
    email={site.email}
    addressStreet={site.addressStreet}
    addressLocality={site.addressLocality}
    addressCountry={site.addressCountry}
    orias={site.orias}
    rcs={site.rcs}
    expertiseLinks={footerExpertiseLinks}
    sectorLinks={footerSectorLinks}
  />
  <StickyMobileCTA />
</BaseLayout>

<style>
  .hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-4); }
  .hero-cues { display: flex; flex-wrap: wrap; gap: var(--space-3) var(--space-6); margin: var(--space-7) 0 0; padding: 0; color: var(--color-text-soft); font-size: var(--font-size-sm); font-weight: var(--font-weight-strong); list-style: none; }
  .hero-cues li { display: flex; align-items: center; gap: var(--space-2); }
  .hero-cues li::before { width: 0.35rem; height: 0.35rem; content: ''; background: var(--color-gold); border-radius: 50%; }

  .risk-map { position: relative; min-height: 31rem; border: 1px solid rgba(18, 54, 95, 0.12); border-radius: var(--radius-panel); background: linear-gradient(145deg, rgba(255,255,255,.82), rgba(240,246,251,.52)); box-shadow: var(--shadow-panel); overflow: hidden; }
  .risk-map::before { position: absolute; inset: 10%; content: ''; border: 1px dashed rgba(18,54,95,.16); border-radius: 50%; }
  .risk-map__orbit { position: absolute; top: 50%; left: 50%; border: 1px solid rgba(201,154,70,.28); border-radius: 50%; transform: translate(-50%,-50%) rotate(-20deg); }
  .risk-map__orbit--one { width: 75%; aspect-ratio: 1; }
  .risk-map__orbit--two { width: 52%; aspect-ratio: 1; }
  .risk-map__core { position: absolute; top: 50%; left: 50%; width: 12.25rem; height: 12.25rem; display: flex; flex-direction: column; align-items: center; justify-content: center; color: white; background: var(--color-brand-deep); border: .6rem solid white; border-radius: 50%; box-shadow: 0 26px 55px rgba(7,28,51,.28); text-align: center; transform: translate(-50%,-50%); }
  .risk-map__core span { color: var(--color-gold-soft); font-size: .7rem; font-weight: 800; letter-spacing: .16em; }
  .risk-map__core strong { margin: .4rem 0 .15rem; font-size: 1.15rem; }
  .risk-map__core small { color: var(--color-text-on-dark-soft); }
  .risk-map__item { position: absolute; min-height: 2.9rem; display: flex; align-items: center; gap: .55rem; padding: .65rem .9rem; color: var(--color-brand-deep); background: rgba(255,255,255,.94); border: 1px solid var(--color-border); border-radius: var(--radius-pill); box-shadow: var(--shadow-card); font-size: .8rem; font-weight: 750; }
  .risk-map__item span { color: var(--color-gold-dark); font-size: .65rem; }
  .risk-map__item--one { top: 12%; left: 9%; }
  .risk-map__item--two { top: 14%; right: 8%; }
  .risk-map__item--three { right: 7%; bottom: 13%; }
  .risk-map__item--four { bottom: 11%; left: 8%; }
  .risk-map__seal { position: absolute; right: 4%; bottom: 43%; width: 5rem; height: 5rem; display: flex; align-items: center; justify-content: center; color: var(--color-brand-ink); background: var(--color-gold-soft); border-radius: 50%; font-size: .7rem; font-weight: 800; line-height: 1.15; text-align: center; transform: rotate(7deg); }

  .trust-strip { position: relative; z-index: 2; padding-block: var(--space-6); background: var(--color-page); border-block: 1px solid var(--color-border); }
  .trust-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: var(--space-3); }
  .split-heading { display: grid; grid-template-columns: 1.15fr .85fr; gap: var(--space-16); align-items: end; margin-bottom: var(--space-10); }
  .split-heading :global(.section-header) { margin-bottom: 0; }
  .split-heading > p { max-width: 35rem; margin: 0; padding-bottom: .35rem; color: var(--color-text-soft); font-size: var(--font-size-body-lg); }
  .problem-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-5); }
  .problem-grid :global(.card) { border-top: 3px solid var(--color-gold); }
  .expertise-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: var(--space-5); }

  .method { color: var(--color-text-on-dark-soft); background: radial-gradient(circle at 20% 15%, rgba(201,154,70,.13), transparent 25%), var(--color-brand-ink); }
  .method__grid { display: grid; grid-template-columns: minmax(0,.85fr) minmax(0,1.15fr); gap: clamp(3rem,8vw,8rem); }
  .method__intro { position: sticky; top: var(--space-8); align-self: start; }
  .method__steps { border-bottom: 1px solid rgba(217,227,238,.18); }

  .transport { background: linear-gradient(110deg, var(--color-page) 0 62%, var(--color-gold-wash) 62%); }
  .transport__grid { display: grid; grid-template-columns: minmax(0,1.05fr) minmax(22rem,.75fr); gap: clamp(3rem,8vw,8rem); align-items: center; }
  .transport__professions { display: flex; flex-wrap: wrap; gap: var(--space-3); }
  .transport__professions span { padding: .65rem .9rem; color: var(--color-brand-deep); background: white; border: 1px solid var(--color-border); border-radius: var(--radius-pill); font-size: var(--font-size-sm); font-weight: 700; }
  .transport__panel { padding: clamp(1.5rem,4vw,3rem); color: white; background: var(--color-brand-deep); border-radius: var(--radius-panel); box-shadow: var(--shadow-panel); }
  .transport__panel h3 { margin: var(--space-4) 0 var(--space-7); font-size: var(--font-size-h3); }
