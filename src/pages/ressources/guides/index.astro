---
import { getCollection } from 'astro:content';
import ResourceHub from '../../../components/ResourceHub.astro';
const entries = (await getCollection('resources', ({ data }) => !data.draft && data.status !== 'archived')).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---
<ResourceHub path="/ressources/guides/" title="Guides sur les assurances d’entreprise" metaTitle="Guides assurance entreprise | Assuromieux Paris" description="Guides pratiques Assuromieux Paris pour auditer les contrats, comprendre les responsabilités et préparer les décisions d’assurance de l’entreprise." eyebrow="Centre de ressources" lead="Des réponses structurées, prudentes et reliées aux contrats. Chaque guide indique ses limites, sa date et les points qui nécessitent une analyse propre à l’entreprise." current="guides" {entries} selectionTitle="Commencer par la décision à préparer." selectionText="Lisez d’abord le guide qui correspond à votre question immédiate, puis utilisez les liens produits pour revenir au contrat concerné." links={[{ href: '/ressources/assurance-entreprise/', label: 'Organiser le programme', text: 'Audit, PME, responsabilités et flotte.' }, { href: '/ressources/transport-logistique/', label: 'Distinguer les risques transport', text: 'Marchandises, véhicules et responsabilités.' }, { href: '/ressources/btp/', label: 'Vérifier le BTP', text: 'Activités, attestations et chantiers.' }]} />
