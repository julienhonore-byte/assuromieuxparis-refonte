---
import { getCollection } from 'astro:content'; import ResourceHub from '../../../components/ResourceHub.astro';
const entries = await getCollection('resources', ({ data }) => !data.draft && data.status !== 'archived' && data.category === 'assurance-entreprise');
---
<ResourceHub path="/ressources/assurance-entreprise/" title="Ressources sur l’assurance entreprise" metaTitle="Ressources assurance entreprise | Assuromieux Paris" description="Guides pour auditer les assurances d’entreprise, organiser les besoins d’une PME et analyser responsabilités, flotte et contrats." eyebrow="Assurance entreprise" lead="Une lecture transversale pour partir de l’activité, hiérarchiser les risques et éviter d’empiler des contrats sans vision d’ensemble." current="assurance-entreprise" {entries} selectionTitle="Relier chaque contrat à un besoin réel." selectionText="Le programme doit rester lisible pour le dirigeant : responsabilités, actifs, véhicules, équipes, données et continuité sont examinés ensemble." links={[{ href: '/audit-assurances-entreprise/', label: 'Découvrir l’audit', text: 'La méthode Assuromieux en quatre temps.' }, { href: '/assurances-entreprises/', label: 'Voir les assurances', text: 'Accéder aux protections transversales.' }, { href: '/lexique/', label: 'Clarifier les termes', text: 'Définitions courtes et prudentes.' }]} />
