---
import ExpertReview from '../components/ExpertReview.astro';
import RelatedResources from '../components/RelatedResources.astro';
import ResourceCTA from '../components/ResourceCTA.astro';
import ResourceHeader from '../components/ResourceHeader.astro';
import ResourceMeta from '../components/ResourceMeta.astro';
import ResourceTableOfContents from '../components/ResourceTableOfContents.astro';
import { productLinks, resourceCategories } from '../data/resources';
import SiteLayout from './SiteLayout.astro';

interface Heading { depth: number; slug: string; text: string; }
interface RelatedItem { href: string; title: string; description: string; }
interface Props {
  title: string; seoTitle?: string; description: string; canonical: string; category: keyof typeof resourceCategories;
  author: string; publishDate: Date; updatedDate: Date; readingTime: number;
  relatedProducts: string[]; faq: { question: string; answer: string }[];
  headings: Heading[]; relatedItems: RelatedItem[]; structuredData: Record<string, unknown>[];
  reviewedBy?: string; reviewDate?: Date;
}
const props = Astro.props;
const category = resourceCategories[props.category];
const products = props.relatedProducts.map((key) => productLinks[key]).filter(Boolean);
---
<SiteLayout title={`${props.seoTitle ?? props.title} | Assuromieux Paris`} description={props.description} canonical={props.canonical} currentPath="/ressources/" structuredData={props.structuredData} ogType="article">
  <main id="contenu-principal">
    <ResourceHeader title={props.title} description={props.description} category={category.name} categoryHref={category.href}>
      <ResourceMeta author={props.author} publishDate={props.publishDate} updatedDate={props.updatedDate} readingTime={props.readingTime} />
    </ResourceHeader>
    <section class="resource-body">
      <div class="container-wide resource-body__grid">
        <aside class="resource-body__aside">
          <ResourceTableOfContents headings={props.headings} />
          <ExpertReview reviewedBy={props.reviewedBy} reviewDate={props.reviewDate} />
        </aside>
        <article class="resource-prose">
          <slot />
          {products.length > 0 && <aside class="product-links" aria-labelledby="product-links-title">
            <h2 id="product-links-title">Assurances et analyses liées</h2>
            <ul>{products.map((product) => <li><a href={product.href}>{product.label}<span aria-hidden="true">→</span></a></li>)}</ul>
          </aside>}
          {props.faq.length > 0 && <section class="resource-faq" aria-labelledby="resource-faq-title">
            <h2 id="resource-faq-title">Questions fréquentes</h2>
            {props.faq.map((item) => <details><summary>{item.question}</summary><p>{item.answer}</p></details>)}
          </section>}
          <ResourceCTA />
        </article>
      </div>
    </section>
    <RelatedResources items={props.relatedItems} />
  </main>
</SiteLayout>

<style>
  .resource-body { padding-block: var(--section-space); }
  .resource-body__grid { display: grid; grid-template-columns: minmax(14rem, 18rem) minmax(0, 48rem); justify-content: center; gap: clamp(2rem, 6vw, 6rem); align-items: start; }
  .resource-prose :global(h2) { margin: var(--space-14) 0 var(--space-5); color: var(--color-brand-deep); font-size: clamp(1.75rem, 1.55rem + .8vw, 2.35rem); line-height: 1.15; scroll-margin-top: 2rem; }
  .resource-prose :global(h2:first-child) { margin-top: 0; }
  .resource-prose :global(h3) { margin: var(--space-8) 0 var(--space-3); color: var(--color-brand-deep); font-size: var(--font-size-h3); line-height: 1.25; }
  .resource-prose :global(p), .resource-prose :global(li) { color: var(--color-text-soft); font-size: 1.0625rem; }
  .resource-prose :global(p) { margin: var(--space-4) 0 0; }
  .resource-prose :global(ul), .resource-prose :global(ol) { display: grid; gap: var(--space-3); margin: var(--space-5) 0 0; padding-left: 1.3rem; }
  .resource-prose :global(blockquote) { margin: var(--space-8) 0; padding: var(--space-5) var(--space-6); color: var(--color-brand-deep); background: var(--color-gold-wash); border-left: 4px solid var(--color-gold); border-radius: var(--radius-control); }
  .resource-prose :global(blockquote p) { margin: 0; color: inherit; font-weight: var(--font-weight-medium); }
  .product-links { margin-top: var(--space-12); padding: var(--space-7); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-card-sm); }
  .product-links h2 { margin: 0; font-size: var(--font-size-h3); }
  .product-links ul { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-2) var(--space-5); padding: 0; list-style: none; }
  .product-links a { min-height: 2.75rem; display: flex; justify-content: space-between; align-items: center; gap: var(--space-3); color: var(--color-brand); font-weight: var(--font-weight-strong); text-decoration: none; }
  .resource-faq { margin-top: var(--space-12); }
  .resource-faq > h2 { margin-top: 0; }
  details { padding-block: var(--space-4); border-top: 1px solid var(--color-border); }
  summary { color: var(--color-brand-deep); font-weight: var(--font-weight-strong); cursor: pointer; }
  details p { padding-right: var(--space-5); }
  @media (max-width: 980px) { .resource-body__grid { grid-template-columns: 1fr; } .resource-body__aside { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(0, .75fr); gap: var(--space-5); } }
  @media (max-width: 640px) { .resource-body__aside, .product-links ul { grid-template-columns: 1fr; } .resource-prose :global(p), .resource-prose :global(li) { font-size: 1rem; } }
</style>
