---
interface Props {
  href: string;
  title: string;
  description: string;
  category: string;
  readingTime?: number;
  featured?: boolean;
}

const { href, title, description, category, readingTime, featured = false } = Astro.props;
---

<article class:list={['resource-card', { 'resource-card--featured': featured }]}>
  <p class="resource-card__meta"><span>{category}</span>{readingTime && <span>{readingTime} min</span>}</p>
  <h3><a href={href}>{title}</a></h3>
  <p>{description}</p>
  <a class="resource-card__link" href={href} aria-label={`Lire : ${title}`}>Lire le guide <span aria-hidden="true">→</span></a>
</article>

<style>
  .resource-card { position: relative; padding: clamp(1.4rem, 3vw, 2rem); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-card-sm); }
  .resource-card--featured { padding: clamp(1.75rem, 4vw, 3rem); border-color: rgba(201, 154, 70, 0.5); box-shadow: var(--shadow-card); }
  .resource-card__meta { display: flex; justify-content: space-between; gap: var(--space-3); margin: 0 0 var(--space-6); color: var(--color-gold-dark); font-size: var(--font-size-xs); font-weight: var(--font-weight-heading); letter-spacing: .06em; text-transform: uppercase; }
  h3 { margin: 0; color: var(--color-brand-deep); font-size: clamp(1.25rem, 1.15rem + .45vw, 1.65rem); line-height: 1.2; }
  h3 a { text-decoration: none; }
  h3 a::after { position: absolute; inset: 0; content: ''; }
  article > p:not(.resource-card__meta) { margin: var(--space-4) 0 0; color: var(--color-text-soft); }
  .resource-card__link { display: inline-flex; gap: var(--space-2); margin-top: var(--space-6); color: var(--color-brand); font-size: var(--font-size-sm); font-weight: var(--font-weight-strong); text-decoration: none; }
  .resource-card:has(h3 a:hover) { border-color: rgba(18, 54, 95, .35); box-shadow: var(--shadow-card-hover); }
</style>
