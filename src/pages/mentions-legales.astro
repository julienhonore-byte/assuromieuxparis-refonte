---
import PageHero from '../components/PageHero.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { breadcrumbSchema, pageUrl } from '../data/seo';

const path = '/mentions-legales/';
const title = 'Mentions légales | Assuromieux Paris';
const description = 'Mentions légales du site Assuromieux Paris : éditeur, publication, hébergement et informations réglementaires.';
const structuredData = breadcrumbSchema([{ name: 'Accueil', path: '/' }, { name: 'Mentions légales', path }]);
---

<SiteLayout {title} {description} canonical={pageUrl(path)} currentPath={path} {structuredData}>
  <main id="contenu-principal">
    <PageHero
      eyebrow="Informations légales"
      title="Mentions légales"
      lead="Cette page rassemble les informations d’identification, de publication et d’hébergement du site Assuromieux Paris."
      breadcrumbs={[{ href: '/', label: 'Accueil' }, { label: 'Mentions légales' }]}
    />

    <article class="section legal-content">
      <div class="container legal-content__inner">
        <section aria-labelledby="editor-title">
          <h2 id="editor-title">Éditeur du site</h2>
          <dl>
            <div><dt>Éditeur</dt><dd>Jules HONORE, entrepreneur individuel, exploitant le site sous le nom commercial ASSUROMIEUX PARIS</dd></div>
            <div><dt>Adresse de l’établissement principal</dt><dd>60 rue François-Ier, 75008 Paris, France</dd></div>
            <div><dt>Immatriculation</dt><dd>SIREN 489 181 032 — SIRET 489 181 032 00033 — RCS Paris — inscrit au Registre national des entreprises</dd></div>
            <div><dt>Activité principale</dt><dd>Activités des agents et courtiers d’assurances — code APE 66.22Z</dd></div>
            <div><dt>TVA intracommunautaire</dt><dd>Le statut TVA doit être confirmé par l’éditeur avant publication d’un numéro.</dd></div>
            <div><dt>Contact</dt><dd><a href="tel:+33695699674">06 95 69 96 74</a> — <a href="mailto:jules@assuromieuxparis.com">jules@assuromieuxparis.com</a></dd></div>
          </dl>
          <p>Les données d’immatriculation peuvent être vérifiées dans <a href="https://annuaire-entreprises.data.gouv.fr/entreprise/489181032" target="_blank" rel="noopener noreferrer">l’Annuaire des Entreprises</a>.</p>
        </section>

        <section aria-labelledby="publication-title">
          <h2 id="publication-title">Direction de la publication</h2>
          <p>Directeur de la publication : Jules HONORE, en qualité d’éditeur du site.</p>
        </section>

        <section aria-labelledby="regulation-title">
          <h2 id="regulation-title">Activité réglementée</h2>
          <dl>
            <div><dt>Qualité</dt><dd>Courtier d’assurance ou de réassurance (COA)</dd></div>
            <div><dt>ORIAS</dt><dd>Immatriculation n° 26003798, vérifiable sur <a href="https://orias.fr/home/showIntermediaire/489181032" target="_blank" rel="noopener noreferrer">orias.fr</a></dd></div>
            <div><dt>Autorité de contrôle</dt><dd>Autorité de contrôle prudentiel et de résolution (ACPR), 4 place de Budapest, CS 92459, 75436 Paris Cedex 09</dd></div>
            <div><dt>Responsabilité civile professionnelle</dt><dd>Contrat souscrit auprès d’ORUS</dd></div>
            <div><dt>Encaissement de fonds</dt><dd>Non autorisé selon le registre ORIAS</dd></div>
            <div><dt>Garantie financière</dt><dd>Non applicable en l’absence d’encaissement de fonds, conformément à l’article L. 512-7 du Code des assurances</dd></div>
          </dl>
          <p>Assuromieux Paris exerce une activité de courtage et de conseil. Les informations du site ne valent ni accord d’un assureur, ni garantie de souscription, de couverture ou d’indemnisation.</p>
        </section>

        <section aria-labelledby="complaints-title">
          <h2 id="complaints-title">Réclamations</h2>
          <p>Toute réclamation peut être adressée par courrier à Assuromieux Paris, 60 rue François-Ier, 75008 Paris, France, ou par courriel à <a href="mailto:jules@assuromieuxparis.com">jules@assuromieuxparis.com</a>, avec l’objet « Réclamation ».</p>
          <p>Un accusé de réception est adressé dans un délai maximal de dix jours ouvrables à compter de la réception de la réclamation, sauf si une réponse est apportée dans ce délai. Une réponse est apportée au plus tard dans les deux mois suivant la réception de la réclamation, hors circonstance particulière dûment justifiée.</p>
        </section>

        <section aria-labelledby="hosting-title">
          <h2 id="hosting-title">Hébergement</h2>
          <p>Le site est hébergé par Netlify, Inc., 101 2nd Street, San Francisco, CA 94105, États-Unis — <a href="https://www.netlify.com/" target="_blank" rel="noopener noreferrer">www.netlify.com</a>.</p>
        </section>

        <section aria-labelledby="rights-title">
          <h2 id="rights-title">Propriété intellectuelle</h2>
          <p>La structure du site ainsi que ses textes, éléments graphiques, logos et contenus sont protégés par les règles applicables à la propriété intellectuelle. Toute reproduction, représentation, adaptation ou exploitation, totale ou partielle, sans autorisation préalable écrite de leur titulaire est interdite, sauf exception prévue par la loi.</p>
        </section>

        <section aria-labelledby="liability-title">
          <h2 id="liability-title">Portée des informations</h2>
          <p>Les contenus du site présentent une démarche générale d’analyse et de courtage. Ils ne constituent pas une garantie de souscription, de couverture ou d’indemnisation. Toute conclusion dépend de l’activité, des informations communiquées, des contrats, des assureurs consultés et des textes applicables.</p>
        </section>
      </div>
    </article>
  </main>
</SiteLayout>

<style>
  .legal-content__inner { max-width: 52rem; }
  .legal-content section + section { margin-top: var(--space-12); }
  .legal-content h2 { color: var(--color-brand-deep); font-size: var(--font-size-h3); }
  dl { display: grid; gap: 1px; margin: var(--space-6) 0 0; background: var(--color-border); border: 1px solid var(--color-border); border-radius: var(--radius-card); overflow: hidden; }
  dl div { display: grid; grid-template-columns: minmax(12rem, .9fr) 1.1fr; gap: var(--space-5); padding: var(--space-5); background: var(--color-surface); }
  dt { color: var(--color-brand-deep); font-weight: var(--font-weight-heading); }
  dd { margin: 0; }
  @media (max-width: 640px) { dl div { grid-template-columns: 1fr; gap: var(--space-2); } }
</style>
