---
interface Item { href: string; title: string; description: string; }
interface Props { items: Item[]; title?: string; }
const { items, title = 'Ressources pour approfondir' } = Astro.props;
---
{items.length > 0 && <section class="related-resources" aria-labelledby="related-resources-title">
  <div class="container">
    <p class="eyebrow">À lire ensuite</p><h2 id="related-resources-title">{title}</h2>
    <div>{items.map((item) => <article><h3><a href={item.href}>{item.title}</a></h3><p>{item.description}</p></article>)}</div>
  </div>
</section>}
<style>
  .related-resources { padding-block: var(--section-space-compact); background: var(--color-surface); border-block: 1px solid var(--color-border); }
  h2 { margin: 0; color: var(--color-brand-deep); font-size: var(--font-size-h2); line-height: var(--line-height-heading); }
  .container > div { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-5); margin-top: var(--space-8); }
  article { padding-top: var(--space-5); border-top: 2px solid var(--color-gold); }
  h3 { margin: 0; font-size: var(--font-size-h4); }
  h3 a { color: var(--color-brand-deep); }
  article p { margin: var(--space-3) 0 0; color: var(--color-text-soft); font-size: var(--font-size-sm); }
  @media (max-width: 640px) { .container > div { grid-template-columns: 1fr; } }
</style>
