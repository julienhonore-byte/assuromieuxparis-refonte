---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import { footerAdviceLinks, footerProductLinks, mainNavigation, site } from '../data/site';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  currentPath: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  ctaHref?: string;
  ctaLabel?: string;
  image?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  canonical,
  currentPath,
  structuredData,
  ctaHref = '/#contact',
  ctaLabel,
  image = site.ogImageUrl,
  ogType = 'website',
} = Astro.props;
---

<BaseLayout {title} {description} {canonical} {image} {structuredData} {ogType}>
  <Header
    items={mainNavigation}
    phoneDisplay={site.phoneDisplay}
    phoneHref={site.phoneHref}
    email={site.email}
    orias={site.orias}
    {currentPath}
    {ctaHref}
    {ctaLabel}
  />
  <slot />
  <Footer
    phoneDisplay={site.phoneDisplay}
    phoneHref={site.phoneHref}
    email={site.email}
    addressStreet={site.addressStreet}
    addressLocality={site.addressLocality}
    addressCountry={site.addressCountry}
    orias={site.orias}
    rcs={site.rcs}
    productLinks={footerProductLinks}
    adviceLinks={footerAdviceLinks}
  />
  <StickyMobileCTA href={ctaHref} label={ctaLabel} />
</BaseLayout>
