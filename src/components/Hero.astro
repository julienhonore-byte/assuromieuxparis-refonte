---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}

const { eyebrow, title, lead } = Astro.props;
---

<section class="hero">
  <div class="container hero__content">
    {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {lead && <p class="hero__lead">{lead}</p>}
    <slot />
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(3.625rem, 8vw, 5.375rem) var(--space-16);
    background:
      radial-gradient(circle at 78% 18%, rgba(201, 154, 70, 0.2), transparent 26%),
      linear-gradient(135deg, #ffffff 0%, #eef5fb 52%, #e6eef7 100%);
  }

  .hero__content {
    max-width: var(--container-max);
  }

  .hero__eyebrow {
    display: inline-flex;
    margin: 0 0 var(--space-6);
    padding: 0.5625rem 0.9375rem;
    color: var(--color-blue-dark);
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(201, 154, 70, 0.42);
    border-radius: var(--radius-pill);
    font-size: 0.8125rem;
    font-weight: var(--font-weight-strong);
  }

  h1 {
    max-width: 13ch;
    margin: 0 0 var(--space-6);
    color: var(--color-blue-dark);
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-heading);
    letter-spacing: -0.06em;
    line-height: 0.98;
  }

  .hero__lead {
    max-width: 42.5rem;
    margin: 0 0 var(--space-8);
    color: var(--color-text-strong);
    font-size: var(--font-size-lead);
  }
</style>
