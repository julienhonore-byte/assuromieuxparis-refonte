---
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';
import PageCTA from '../components/PageCTA.astro';
import PageHero from '../components/PageHero.astro';
import ProductSelector from '../components/ProductSelector.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import RelatedResources from '../components/RelatedResources.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SolutionMethod from '../components/SolutionMethod.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { transversalProducts } from '../data/products';
import { baseSchemas, breadcrumbSchema, pageUrl, serviceSchema } from '../data/seo';

const path = '/assurances-entreprises/';
const description = 'Assurances entreprises à Paris : analyse globale de la RC professionnelle, multirisque, flotte, cyber, santé, prévoyance et protection du dirigeant.';
const faqItems = [
  { question: 'Quelles assurances une entreprise doit-elle étudier ?', answer: 'Le périmètre dépend de l’activité, des actifs, des salariés et des engagements pris. RC professionnelle, multirisque, flotte, santé, prévoyance, protection du dirigeant et cyberassurance sont des points fréquents, mais ils ne sont pas systématiquement nécessaires dans les mêmes conditions.' },
  { question: 'Pourquoi analyser plusieurs contrats ensemble ?', answer: 'Un même événement peut concerner plusieurs garanties. Une lecture globale aide à repérer les écarts de déclaration, les doublons apparents, les franchises qui se cumulent et les zones insuffisamment traitées.' },
  { question: 'Le prix est-il le premier critère de comparaison ?', answer: 'Le coût compte, mais il doit être rapproché des garanties, exclusions, plafonds, franchises et conditions de gestion. Une prime plus basse n’est utile que si la protection reste cohérente.' },
];
const structuredData = [
  ...baseSchemas,
  breadcrumbSchema([{ name: 'Accueil', path: '/' }, { name: 'Assurances entreprises', path }]),
  serviceSchema('Conseil en assurances d’entreprise', description, path),
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqItems.map((item) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })) },
];
---

<SiteLayout title="Assurances entreprises à Paris | Assuromieux Paris" {description} canonical={pageUrl(path)} currentPath={path} {structuredData}>
  <main id="contenu-principal">
    <PageHero
      eyebrow="Assurances professionnelles"
      title="Piloter les assurances de l’entreprise comme un seul programme."
      lead="Nous relions responsabilités, actifs, équipes et continuité afin de rendre les protections et les arbitrages plus lisibles."
      breadcrumbs={[{ href: '/', label: 'Accueil' }, { label: 'Assurances entreprises' }]}
    >
      <CTA href="#protections" label="Voir les assurances" size="large" />
      <CTA href="/audit-assurances-entreprise/" label="Découvrir l’audit" variant="secondary" size="large" />
    </PageHero>

    <section class="section" aria-labelledby="public-title">
      <div class="container-wide content-grid">
        <div class="content-copy">
          <p class="eyebrow">À qui s’adresse notre approche ?</p>
          <h2 id="public-title">Aux entreprises qui veulent une vision claire de leur protection.</h2>
        </div>
        <div class="content-copy">
          <p>Assuromieux Paris accompagne notamment les PME, artisans, entreprises de services, commerces, professions libérales et dirigeants. L’analyse part de l’activité réelle, pas d’une liste de produits imposée.</p>
          <p>Elle devient particulièrement utile lorsque l’entreprise évolue, que les contrats se sont accumulés ou qu’une échéance importante approche.</p>
        </div>
      </div>
    </section>

    <section id="protections" class="section section--surface" aria-labelledby="protections-title">
      <div class="container-wide">
        <SectionHeader kicker="Risques & besoins couverts" title="Les protections transversales à examiner." text="Chaque entrée ouvre directement le point correspondant ; le besoin exact reste à confirmer selon votre situation." id="protections-title" />
        <ProductSelector products={transversalProducts} compact />
      </div>
    </section>

    <section class="section" aria-labelledby="checks-title">
      <div class="container-wide content-grid content-grid--reverse">
        <div class="editorial-panel">
          <h2 id="checks-title">Points à vérifier</h2>
          <ul>
            <li>activités et chiffres déclarés ;</li>
            <li>plafonds, franchises et exclusions ;</li>
            <li>articulation entre les contrats ;</li>
            <li>échéances et informations à actualiser.</li>
          </ul>
        </div>
        <div class="content-copy">
          <p class="eyebrow">Une lecture d’ensemble</p>
          <h2>Comparer la protection avant de comparer la prime.</h2>
          <p>Les contrats sont rapprochés des obligations, des actifs et des responsabilités de l’entreprise. Cette lecture fait apparaître ce qui reste pertinent, ce qui doit évoluer et ce qui mérite une consultation du marché.</p>
          <p class="notice">Une recommandation ne conduit pas automatiquement à changer d’assureur : conserver ou ajuster un contrat peut être la décision la plus cohérente.</p>
        </div>
      </div>
    </section>

    <SolutionMethod />

    <section class="section section--surface" aria-labelledby="faq-title">
      <div class="container faq-layout">
        <SectionHeader kicker="Questions fréquentes" title="Comprendre le programme d’assurances." id="faq-title" />
        <FAQ items={faqItems} />
      </div>
    </section>

    <RelatedLinks items={[
      { href: '/audit-assurances-entreprise/', label: 'Audit des assurances', text: 'Mettre les contrats en regard de l’activité.' },
      { href: '/assurance-transport/', label: 'Transport et logistique', text: 'Approfondir les risques de véhicules et de flux.' },
      { href: '/assurance-btp-decennale/', label: 'BTP et décennale', text: 'Relier activités, chantiers et attestations.' },
    ]} />
    <RelatedResources items={[
      { href: '/ressources/guides/comment-auditer-assurances-entreprise/', title: 'Comment auditer les assurances de son entreprise ?', description: 'Une méthode ordonnée pour rapprocher activité, contrats et échéances.' },
      { href: '/ressources/guides/quelles-assurances-prevoir-pme/', title: 'Quelles assurances prévoir pour une PME ?', description: 'Une grille de décision sans liste universelle.' },
      { href: '/ressources/guides/rc-professionnelle-rc-exploitation-differences/', title: 'RC professionnelle et RC exploitation', description: 'Les différences à vérifier avant de conclure.' },
      { href: '/ressources/guides/flotte-automobile-points-analyser-avant-comparer/', title: 'Assurance flotte : les points à analyser', description: 'Parc, conducteurs, usages, sinistralité et franchises.' },
    ]} />
    <PageCTA title="Votre programme mérite une lecture d’ensemble." text="Un premier échange permet de définir les contrats prioritaires et l’échéance utile pour commencer." secondaryHref="/cabinet/" secondaryLabel="Découvrir le cabinet" />
  </main>
</SiteLayout>

<style>.faq-layout { max-width: 58rem; }</style>
