---
interface Stage { title: string; text: string; }
interface Props {
  eyebrow?: string;
  title: string;
  intro: string;
  stages: Stage[];
  variant?: 'line' | 'staggered';
}

const { eyebrow = 'Comprendre l’activité', title, intro, stages, variant = 'line' } = Astro.props;
---

<section class:list={['section', 'sector-journey', `sector-journey--${variant}`]} aria-labelledby="sector-journey-title">
  <div class="container-wide">
    <header>
      <div><p class="eyebrow">{eyebrow}</p><h2 id="sector-journey-title">{title}</h2></div>
      <p>{intro}</p>
    </header>
    <ol>
      {stages.map((stage, index) => <li><span>{String(index + 1).padStart(2, '0')}</span><h3>{stage.title}</h3><p>{stage.text}</p></li>)}
    </ol>
  </div>
</section>

<style>
  header { display: grid; grid-template-columns: minmax(0, 1fr) minmax(18rem, .58fr); gap: clamp(2rem, 7vw, 7rem); align-items: end; }
  h2 { max-width: 18ch; margin: 0; color: var(--color-brand-ink); font-size: var(--font-size-h2); letter-spacing: var(--letter-spacing-heading); line-height: var(--line-height-heading); }
  header > p { margin: 0; color: var(--color-text-soft); }
  ol { position: relative; display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: clamp(1.25rem, 3vw, 3rem); margin: clamp(2.75rem, 5vw, 4.75rem) 0 0; padding: 0; list-style: none; }
  ol::before { position: absolute; top: 1.1rem; right: 0; left: 0; height: 1px; content: ''; background: linear-gradient(90deg, var(--color-gold), var(--color-border)); }
  li { position: relative; z-index: 1; padding-top: 3.3rem; }
  li > span { position: absolute; top: 0; left: 0; width: 2.2rem; height: 2.2rem; display: grid; place-items: center; color: var(--color-gold-dark); background: var(--color-surface); border: 1px solid var(--color-gold); border-radius: 50%; font-size: var(--font-size-xs); font-weight: var(--font-weight-heading); }
  h3 { margin: 0; color: var(--color-brand-deep); font-size: var(--font-size-h4); line-height: 1.25; }
  li p { margin: var(--space-3) 0 0; color: var(--color-text-soft); font-size: var(--font-size-sm); }
  .sector-journey--staggered li:nth-child(even) { margin-top: var(--space-8); }
  @media (max-width: 860px) { header { grid-template-columns: 1fr; align-items: start; } ol { grid-template-columns: repeat(2, minmax(0, 1fr)); } ol::before { display: none; } .sector-journey--staggered li:nth-child(even) { margin-top: 0; } }
  @media (max-width: 560px) { ol { grid-template-columns: 1fr; } }
</style>
