---
import { getCollection } from 'astro:content'; import ResourceHub from '../../../components/ResourceHub.astro';
const all = await getCollection('resources', ({ data }) => !data.draft && data.status !== 'archived');
const entries = all.filter((entry) => entry.data.category === 'dirigeants' || entry.data.tags.includes('dirigeant') || entry.data.tags.includes('PME'));
---
<ResourceHub path="/ressources/dirigeants/" title="Ressources pour les dirigeants" metaTitle="Guides assurance pour dirigeants | Assuromieux Paris" description="Repères pour aider les dirigeants à organiser le programme d’assurances, préparer un audit et distinguer les besoins de l’entreprise et de la personne." eyebrow="Parcours dirigeant" lead="Un parcours de décision qui commence par l’entreprise et distingue ensuite responsabilités, revenus, personnes-clés et continuité." current="dirigeants" {entries} selectionTitle="Garder une vision d’ensemble." selectionText="La protection de l’entreprise, celle du dirigeant et les conséquences de son indisponibilité ne doivent pas être confondues. Chaque sujet appelle ses propres données." links={[{ href: '/protection-dirigeant/', label: 'Protection du dirigeant', text: 'Statut, revenus, responsabilité et continuité.' }, { href: '/assurances-entreprises/', label: 'Programme d’assurances', text: 'Relier les protections transversales.' }, { href: '/audit-assurances-entreprise/', label: 'Préparer un audit', text: 'Choisir les contrats prioritaires.' }]} />
