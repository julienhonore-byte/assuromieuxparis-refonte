---
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';
import PageCTA from '../components/PageCTA.astro';
import PageHero from '../components/PageHero.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import RelatedResources from '../components/RelatedResources.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SolutionMethod from '../components/SolutionMethod.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { baseSchemas, breadcrumbSchema, pageUrl, serviceSchema } from '../data/seo';

const path = '/assurance-btp-decennale/';
const description = 'Assurance BTP et décennale : analyse des activités déclarées, attestations, procédés, sous-traitance, véhicules et multirisque.';
const faqItems = [
  { question: 'La décennale suffit-elle à couvrir une entreprise du BTP ?', answer: 'Non. Selon l’activité, il faut aussi examiner la RC professionnelle, les locaux, matériels, véhicules, salariés, sous-traitants et conséquences d’une interruption d’activité.' },
  { question: 'Pourquoi vérifier les activités déclarées ?', answer: 'L’attestation et le contrat doivent rester cohérents avec les travaux réellement réalisés. Les libellés, procédés et évolutions d’activité méritent donc une lecture attentive.' },
  { question: 'Quels documents préparer ?', answer: 'Les contrats et attestations, la description des activités, leur part de chiffre d’affaires, les procédés utilisés, l’organisation de la sous-traitance et les principaux types de chantiers.' },
];
const structuredData = [
  ...baseSchemas,
  breadcrumbSchema([{ name: 'Accueil', path: '/' }, { name: 'Assurance BTP et décennale', path }]),
  serviceSchema('Conseil en assurance BTP et décennale', description, path),
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqItems.map((item) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })) },
];
---

<SiteLayout title="Assurance BTP et décennale | Assuromieux Paris" {description} canonical={pageUrl(path)} currentPath={path} {structuredData}>
  <main id="contenu-principal">
    <PageHero
      eyebrow="Expertise sectorielle"
      title="Relier la décennale aux activités réellement exercées."
      lead="Nous examinons les activités, attestations, procédés, chantiers et autres contrats pour améliorer la cohérence du programme BTP."
      breadcrumbs={[{ href: '/', label: 'Accueil' }, { label: 'Assurance BTP et décennale' }]}
    >
      <CTA href="/#contact" label="Demander un audit BTP" size="large" />
      <CTA href="#risques" label="Voir les risques" variant="secondary" size="large" />
    </PageHero>

    <section class="section" aria-labelledby="public-title">
      <div class="container-wide content-grid">
        <div class="content-copy">
          <p class="eyebrow">À qui s’adresse cette solution ?</p>
          <h2 id="public-title">Aux artisans et entreprises qui réalisent ou coordonnent des travaux.</h2>
        </div>
        <div class="content-copy">
          <p>L’approche concerne les professionnels du bâtiment, les entreprises intervenant sur plusieurs corps d’état et les structures qui font évoluer leurs techniques, leurs marchés ou leur recours à la sous-traitance.</p>
          <p>Le point de départ reste simple : rapprocher ce qui est déclaré de ce qui est réellement réalisé.</p>
        </div>
      </div>
    </section>

    <section id="risques" class="section section--surface" aria-labelledby="risks-title">
      <div class="container-wide">
        <SectionHeader kicker="Risques couverts" title="Quatre dimensions du programme BTP." id="risks-title" />
        <div class="feature-grid feature-grid--2">
          {[
            ['Décennale et attestations', 'Activités déclarées, période, portée et cohérence avec les travaux.'],
            ['RC professionnelle', 'Responsabilités avant, pendant et autour de la réalisation.'],
            ['Véhicules et matériels', 'Parc, engins, usages, locaux, dépôts et équipements.'],
            ['Entreprise et dirigeant', 'Sous-traitance, équipes, continuité et protection du décideur.'],
          ].map(([title, text]) => <article class="feature-item"><h3>{title}</h3><p>{text}</p></article>)}
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="checks-title">
      <div class="container-wide content-grid content-grid--reverse">
        <div class="editorial-panel">
          <h2 id="checks-title">Points à vérifier</h2>
          <ul>
            <li>libellés et répartition des activités ;</li>
            <li>procédés et techniques employés ;</li>
            <li>types de chantiers et donneurs d’ordre ;</li>
            <li>organisation de la sous-traitance ;</li>
            <li>attestations et périodes de garantie ;</li>
            <li>véhicules, locaux et matériels.</li>
          </ul>
        </div>
        <div class="content-copy">
          <p class="eyebrow">Un contrôle pragmatique</p>
          <h2>Repérer les écarts avant qu’ils ne deviennent une difficulté.</h2>
          <p>L’audit organise les informations, met en évidence les incohérences et précise les sujets à présenter au marché. Il facilite aussi la mise à jour des attestations et des données d’activité.</p>
          <p class="notice"><strong>Limite importante :</strong> cette analyse ne constitue pas un conseil juridique définitif. Une question de qualification d’activité ou de responsabilité peut nécessiter un professionnel du droit.</p>
        </div>
      </div>
    </section>

    <SolutionMethod title="Une méthode commune, adaptée au BTP." text="Les quatre temps Assuromieux sont appliqués aux activités, attestations et autres contrats du programme. Le suivi accompagne ensuite les évolutions de l’entreprise." />

    <section class="section section--surface" aria-labelledby="faq-title">
      <div class="container faq-layout">
        <SectionHeader kicker="Questions fréquentes" title="Avant de vérifier les contrats BTP." id="faq-title" />
        <FAQ items={faqItems} />
      </div>
    </section>

    <RelatedLinks items={[
      { href: '/audit-assurances-entreprise/', label: 'Audit des assurances', text: 'Découvrir le déroulement de l’analyse.' },
      { href: '/rc-professionnelle/', label: 'RC professionnelle', text: 'Distinguer responsabilité décennale, professionnelle et exploitation.' },
      { href: '/multirisque-professionnelle/', label: 'Multirisque professionnelle', text: 'Relier locaux, matériels et continuité d’activité.' },
    ]} />
    <RelatedResources items={[
      { href: '/ressources/guides/assurance-decennale-coherence-activites-attestation/', title: 'Décennale : vérifier activités et attestation', description: 'Une méthode prudente pour rapprocher travaux, périodes, procédés et sous-traitance.' },
    ]} />
    <PageCTA title="Vérifions la cohérence de vos activités et de vos contrats." text="Un premier échange permet d’identifier les attestations et échéances à examiner en priorité." />
  </main>
</SiteLayout>

<style>.faq-layout { max-width: 58rem; }</style>
