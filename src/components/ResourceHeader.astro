---
import Breadcrumbs from './Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  categoryHref: string;
}

const { title, description, category, categoryHref } = Astro.props;
---

<header class="resource-header">
  <div class="container resource-header__inner">
    <Breadcrumbs items={[{ href: '/', label: 'Accueil' }, { href: '/ressources/', label: 'Ressources' }, { href: categoryHref, label: category }, { label: title }]} />
    <p class="eyebrow">Guide pratique · {category}</p>
    <h1>{title}</h1>
    <p class="resource-header__lead">{description}</p>
    <slot />
  </div>
</header>

<style>
  .resource-header { padding-bottom: clamp(3rem, 7vw, 5.5rem); background: linear-gradient(135deg, var(--color-surface), var(--color-page) 72%); border-bottom: 1px solid var(--color-border); }
  .resource-header__inner { max-width: 60rem; }
  h1 { max-width: 19ch; margin: var(--space-5) 0 0; color: var(--color-brand-ink); font-size: clamp(2.4rem, 1.75rem + 2.7vw, 4.4rem); font-weight: var(--font-weight-heading); letter-spacing: var(--letter-spacing-display); line-height: 1.02; }
  .resource-header__lead { max-width: 47rem; margin: var(--space-6) 0 0; color: var(--color-text-soft); font-size: var(--font-size-lead); }
</style>
