---
import type { InsuranceProduct } from '../data/products';

interface Props {
  products: InsuranceProduct[];
  compact?: boolean;
  variant?: 'cards' | 'editorial';
}

const { products, compact = false, variant = 'cards' } = Astro.props;
---

<ol class:list={['product-selector', `product-selector--${variant}`, { 'product-selector--compact': compact }]}>
  {products.map((product, index) => (
    <li>
      <a href={product.href} aria-label={`${product.cta} : ${product.name}`} data-product-slug={product.slug}>
        <span class="product-selector__index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
        <span class="product-selector__copy">
          <strong>{product.name}</strong>
          <small>{product.description}</small>
        </span>
        <span class="product-selector__cta">{product.cta}<i aria-hidden="true">→</i></span>
      </a>
    </li>
  ))}
</ol>

<script>
  const selectedProductKey = 'assuromieux:selected-product';

  document.querySelectorAll<HTMLElement>('[data-product-slug]').forEach((link) => {
    link.addEventListener('click', () => {
      const slug = link.dataset.productSlug;
      if (!slug) return;

      try {
        window.sessionStorage.setItem(selectedProductKey, slug);
      } catch {
        // Le parcours reste entièrement fonctionnel lorsque le stockage est indisponible.
      }
    });
  });
</script>

<style>
  .product-selector {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    margin: 0;
    padding: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-panel);
    overflow: hidden;
    list-style: none;
    box-shadow: var(--shadow-card);
  }

  li { min-width: 0; background: var(--color-surface); }

  a {
    min-height: 9rem;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3) var(--space-4);
    align-content: start;
    padding: clamp(1.1rem, 2.1vw, 1.55rem);
    color: var(--color-text);
    text-decoration: none;
    transition: background var(--transition-base), color var(--transition-base);
  }

  a:hover { color: var(--color-brand-deep); background: var(--color-page-soft); }

  .product-selector__index {
    color: var(--color-gold-dark);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-heading);
    letter-spacing: .08em;
  }

  .product-selector__copy { min-width: 0; display: grid; gap: var(--space-2); }
  strong { color: var(--color-brand-deep); line-height: 1.2; }
  small { color: var(--color-text-soft); font-size: var(--font-size-sm); line-height: 1.45; }

  .product-selector__cta {
    grid-column: 2;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-brand);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-strong);
  }

  .product-selector__cta i { font-style: normal; transition: transform var(--transition-fast); }
  a:hover .product-selector__cta i { transform: translateX(.2rem); }

  .product-selector--compact { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .product-selector--compact a { min-height: 8.25rem; }

  .product-selector--editorial {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0 clamp(2rem, 6vw, 6.5rem);
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .product-selector--editorial li {
    border-top: 1px solid var(--color-border);
  }

  .product-selector--editorial li:nth-last-child(-n + 2) {
    border-bottom: 1px solid var(--color-border);
  }

  .product-selector--editorial a {
    min-height: 7.25rem;
    grid-template-columns: 2rem minmax(0, 1fr) auto;
    align-content: center;
    align-items: center;
    gap: var(--space-2) var(--space-4);
    padding: var(--space-5) 0;
    background: transparent;
  }

  .product-selector--editorial a:hover {
    background: transparent;
  }

  .product-selector--editorial a:hover strong {
    color: var(--color-brand);
  }

  .product-selector--editorial .product-selector__copy {
    gap: var(--space-1);
  }

  .product-selector--editorial .product-selector__cta {
    grid-column: auto;
    color: var(--color-text-muted);
  }

  .product-selector--editorial .product-selector__cta i {
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-deep);
    border: 1px solid var(--color-border-strong);
    border-radius: 50%;
  }

  @media (max-width: 860px) {
    .product-selector { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 540px) {
    .product-selector,
    .product-selector--compact { grid-template-columns: 1fr; }
    a { min-height: 0; }

    .product-selector--editorial {
      gap: 0;
    }

    .product-selector--editorial li:nth-last-child(-n + 2) {
      border-bottom: 0;
    }

    .product-selector--editorial li:last-child {
      border-bottom: 1px solid var(--color-border);
    }

    .product-selector--editorial a {
      min-height: 6.5rem;
      grid-template-columns: 1.5rem minmax(0, 1fr) auto;
      gap: var(--space-2) var(--space-3);
    }

    .product-selector--editorial .product-selector__cta {
      font-size: 0;
    }

    .product-selector--editorial .product-selector__cta i {
      font-size: var(--font-size-sm);
    }
  }
</style>
