---
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Card from '../../components/Card.astro';
import ContactForm from '../../components/ContactForm.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { footerExpertiseLinks, footerSectorLinks, mainNavigation, site } from '../../data/site';
---

<BaseLayout title="Démonstration interne | Assuromieux Paris" description="Démonstration locale non publiée du système graphique Assuromieux Paris.">
  <Header items={mainNavigation} phoneDisplay={site.phoneDisplay} phoneHref={site.phoneHref} email={site.email} orias={site.orias} currentPath="/demo" />
  <main id="contenu-principal">
    <div class="container"><Breadcrumbs items={[{ href: '/', label: 'Accueil' }, { label: 'Démonstration interne' }]} /></div>
    <Hero eyebrow="Démonstration interne" title="Le système graphique Assuromieux Paris" lead="Couleurs, typographie, boutons, cartes, formulaire, header et footer dans leur contexte réel.">
      <div class="demo-actions"><CTA href="#cartes" label="Voir les composants" /><CTA href="#formulaire" label="Voir le formulaire" variant="secondary" /></div>
      <div slot="visual" class="demo-mark" aria-hidden="true">Aa</div>
    </Hero>
    <section class="section section--surface"><div class="container-wide"><SectionHeader kicker="Couleurs" title="Palette de marque" /><div class="swatches"><div class="swatch blue">#12365f</div><div class="swatch deep">#0b2747</div><div class="swatch gold">#c99a46</div><div class="swatch wash">#fbf5e9</div></div></div></section>
    <section id="cartes" class="section"><div class="container-wide"><SectionHeader kicker="Composants" title="Titres, boutons et cartes" /><div class="demo-grid"><Card title="Audit" text="Analyse structurée du besoin et des contrats." /><Card title="Diagnostic" text="Lecture claire des garanties et exclusions." tone="soft" /><Card title="Accompagnement" text="Une recommandation expliquée et suivie." tone="gold" /></div></div></section>
    <section id="formulaire" class="section section--surface"><div class="container demo-form"><SectionHeader kicker="Formulaire" title="Formspree accessible" text="Démonstration technique : ne pas envoyer de données réelles." /><ContactForm action={site.formspreeUrl} calUrl={site.calUrl} /></div></section>
  </main>
  <Footer phoneDisplay={site.phoneDisplay} phoneHref={site.phoneHref} email={site.email} addressStreet={site.addressStreet} addressLocality={site.addressLocality} addressCountry={site.addressCountry} orias={site.orias} rcs={site.rcs} expertiseLinks={footerExpertiseLinks} sectorLinks={footerSectorLinks} />
</BaseLayout>

<style>
  .demo-actions { display: flex; flex-wrap: wrap; gap: var(--space-4); }
  .demo-mark { display: grid; place-items: center; min-height: 24rem; color: white; background: var(--color-brand-deep); border: 1rem solid var(--color-gold-wash); border-radius: 50%; font-size: clamp(7rem, 18vw, 13rem); font-weight: 850; letter-spacing: -.1em; }
  .swatches, .demo-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: var(--space-4); }
  .demo-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .swatch { min-height: 9rem; display: flex; align-items: end; padding: var(--space-4); border-radius: var(--radius-card-sm); font-weight: 750; }
  .blue, .deep { color: white; } .blue { background: var(--color-brand); } .deep { background: var(--color-brand-deep); } .gold { background: var(--color-gold); } .wash { background: var(--color-gold-wash); border: 1px solid var(--color-border); }
  .demo-form { max-width: var(--container-reading); }
  @media (max-width: 768px) { .swatches, .demo-grid { grid-template-columns: 1fr; } }
</style>
