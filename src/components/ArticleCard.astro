---
interface Props {
  type: string;
  title: string;
  summary: string;
  status?: string;
  href?: string;
}

const { type, title, summary, status = 'Guide', href } = Astro.props;
---

<article class="article-card card">
  <div class="article-card__meta">
    <span>{type}</span>
    <strong>{status}</strong>
  </div>
  <h3>{href ? <a href={href}>{title}</a> : title}</h3>
  <p>{summary}</p>
  {href && <a class="article-card__link" href={href}>Lire le guide <span aria-hidden="true">→</span></a>}
</article>

<style>
  .article-card {
    position: relative;
    min-height: 18rem;
    display: flex;
    flex-direction: column;
  }

  h3 a { color: inherit; text-decoration: none; }
  h3 a::after { position: absolute; inset: 0; content: ''; }
  .article-card__link { margin-top: var(--space-5); color: var(--color-brand); font-size: var(--font-size-sm); font-weight: var(--font-weight-strong); text-decoration: none; }

  .article-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: auto;
    padding-bottom: var(--space-10);
    color: var(--color-gold-dark);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-heading);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .article-card__meta strong {
    padding: 0.35rem 0.65rem;
    color: var(--color-text-soft);
    background: var(--color-page);
    border-radius: var(--radius-pill);
    letter-spacing: 0;
    text-transform: none;
  }
</style>
