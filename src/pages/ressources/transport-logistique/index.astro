---
import { getCollection } from 'astro:content'; import ResourceHub from '../../../components/ResourceHub.astro';
const entries = await getCollection('resources', ({ data }) => !data.draft && data.status !== 'archived' && data.category === 'transport-logistique');
---
<ResourceHub path="/ressources/transport-logistique/" title="Ressources transport & logistique" metaTitle="Guides assurance transport et logistique | Assuromieux Paris" description="Guides pour distinguer responsabilité transporteur, marchandises, flotte automobile, sous-traitance et risques logistiques." eyebrow="Expertise sectorielle" lead="Le transport exige de séparer les véhicules, les marchandises, les responsabilités et les rôles. Ces ressources préparent l’analyse sans remplacer les textes ni les contrats." current="transport-logistique" {entries} selectionTitle="Lire la chaîne d’exploitation, pas un risque isolé." selectionText="Les flux relient plusieurs acteurs et contrats. Une question sur la marchandise conduit souvent à vérifier aussi le véhicule, la mission et la sous-traitance." links={[{ href: '/assurance-transport/', label: 'Assurance transport', text: 'Le hub sectoriel et ses quatre ensembles de risques.' }, { href: '/flotte-automobile/', label: 'Flotte automobile', text: 'Parc, conducteurs, usages et sinistralité.' }, { href: '/audit-assurances-entreprise/', label: 'Audit des assurances', text: 'Structurer les documents et échéances.' }]} />
