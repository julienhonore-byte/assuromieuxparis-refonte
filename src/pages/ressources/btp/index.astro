---
import { getCollection } from 'astro:content'; import ResourceHub from '../../../components/ResourceHub.astro';
const entries = await getCollection('resources', ({ data }) => !data.draft && data.status !== 'archived' && data.category === 'btp');
---
<ResourceHub path="/ressources/btp/" title="Ressources BTP et décennale" metaTitle="Guides assurance BTP et décennale | Assuromieux Paris" description="Guides prudents pour préparer la vérification des activités, attestations, procédés, chantiers, dates et sous-traitance dans le BTP." eyebrow="Expertise sectorielle" lead="Les qualifications juridiques et les garanties exigent une lecture précise. Les guides organisent les contrôles sans produire de conclusion automatique." current="btp" {entries} selectionTitle="Préparer les pièces avant de qualifier." selectionText="Activités, rôles, procédés, contrats et dates doivent être rapprochés. Les cas sensibles restent soumis à une validation métier ou juridique." links={[{ href: '/assurance-btp-decennale/', label: 'Assurance BTP et décennale', text: 'Le hub sectoriel et le programme global.' }, { href: '/rc-professionnelle/', label: 'RC professionnelle', text: 'Distinguer les responsabilités autour des travaux.' }, { href: '/audit-assurances-entreprise/', label: 'Audit des assurances', text: 'Organiser contrats, attestations et échéances.' }]} />
