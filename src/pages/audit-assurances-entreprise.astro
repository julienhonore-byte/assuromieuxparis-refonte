---
import CTA from '../components/CTA.astro';
import FAQ from '../components/FAQ.astro';
import PageCTA from '../components/PageCTA.astro';
import PageHero from '../components/PageHero.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SolutionMethod from '../components/SolutionMethod.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { baseSchemas, breadcrumbSchema, pageUrl, serviceSchema } from '../data/seo';

const path = '/audit-assurances-entreprise/';
const description = 'Audit des assurances d’entreprise : analyse des contrats, risques, garanties et conditions pour éclairer les arbitrages du dirigeant.';
const faqItems = [
  { question: 'Quand demander un audit de ses assurances ?', answer: 'Avant une échéance importante, après une évolution d’activité, une hausse sensible de cotisation ou lorsque plusieurs contrats ont été ajoutés sans vision consolidée.' },
  { question: 'Quels documents faut-il préparer ?', answer: 'Les contrats et avenants disponibles, les appels de cotisation, une description de l’activité et, selon le périmètre, les éléments de sinistralité, de flotte, de locaux ou d’obligations clients.' },
  { question: 'L’audit impose-t-il de changer d’assureur ?', answer: 'Non. La conclusion peut être de conserver un contrat, de le faire évoluer ou de consulter le marché. Le changement n’est pas un objectif en soi.' },
  { question: 'Quel livrable est remis ?', answer: 'Le format dépend du périmètre. Il synthétise les contrats étudiés, les points de vigilance, les priorités et les scénarios à arbitrer avec le dirigeant.' },
];
const structuredData = [
  ...baseSchemas,
  breadcrumbSchema([{ name: 'Accueil', path: '/' }, { name: 'Audit des assurances entreprise', path }]),
  serviceSchema('Audit des assurances d’entreprise', description, path),
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqItems.map((item) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })) },
];
---

<SiteLayout title="Audit des assurances entreprise | Assuromieux Paris" {description} canonical={pageUrl(path)} currentPath={path} {structuredData}>
  <main id="contenu-principal">
    <PageHero
      eyebrow="Audit assurance entreprise"
      title="Décider avec une vision claire de ses contrats."
      lead="Nous rapprochons votre activité, vos risques et vos assurances pour faire apparaître les priorités et les arbitrages utiles."
      breadcrumbs={[{ href: '/', label: 'Accueil' }, { label: 'Audit des assurances entreprise' }]}
    >
      <CTA href="/#contact" label="Demander mon audit" size="large" />
      <CTA href="#besoins" label="Voir le périmètre" variant="secondary" size="large" />
    </PageHero>

    <section class="section" aria-labelledby="public-title">
      <div class="container-wide content-grid">
        <div class="content-copy">
          <p class="eyebrow">À qui s’adresse l’audit ?</p>
          <h2 id="public-title">Aux dirigeants qui ont besoin de comprendre avant de renouveler.</h2>
        </div>
        <div class="content-copy">
          <p>L’audit est adapté lorsqu’une entreprise change d’activité, de locaux ou de parc, prépare une échéance, subit une hausse de cotisation ou ne dispose plus d’une vue consolidée de ses contrats.</p>
          <p>Il peut porter sur une assurance prioritaire ou sur l’ensemble du programme. Le périmètre est défini avant toute analyse.</p>
        </div>
      </div>
    </section>

    <section id="besoins" class="section section--surface" aria-labelledby="needs-title">
      <div class="container-wide">
        <SectionHeader kicker="Risques & besoins" title="Quatre questions structurent le diagnostic." id="needs-title" />
        <div class="feature-grid feature-grid--2">
          {[
            ['L’activité est-elle bien décrite ?', 'Les déclarations, prestations et engagements sont rapprochés de la réalité opérationnelle.'],
            ['Les garanties répondent-elles au risque ?', 'Plafonds, franchises, exclusions et limites sont lus dans leur contexte.'],
            ['Les contrats fonctionnent-ils ensemble ?', 'Les doublons apparents et les zones insuffisamment traitées sont examinés.'],
            ['Les conditions restent-elles pertinentes ?', 'Coûts, échéances et qualité de présentation du risque sont mis en perspective.'],
          ].map(([title, text]) => <article class="feature-item"><h3>{title}</h3><p>{text}</p></article>)}
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="checks-title">
      <div class="container-wide content-grid content-grid--reverse">
        <div class="editorial-panel">
          <h2 id="checks-title">Documents utiles</h2>
          <ul>
            <li>contrats, avenants et appels de cotisation ;</li>
            <li>description des activités et évolutions récentes ;</li>
            <li>éléments de sinistralité disponibles ;</li>
            <li>parc, locaux ou obligations liés au périmètre.</li>
          </ul>
        </div>
        <div class="content-copy">
          <p class="eyebrow">Points à vérifier</p>
          <h2>Le prix n’est jamais lu isolément.</h2>
          <p>Une comparaison utile rapproche la prime du niveau de protection, des franchises, des exclusions, des obligations de l’entreprise et des conditions proposées par le marché.</p>
          <p>La restitution distingue les points cohérents, les vigilances, les priorités et les options à approfondir.</p>
          <p class="notice"><strong>Limite :</strong> l’audit ne garantit ni économie automatique, ni acceptation par un assureur, ni absence de sinistre. Il ne remplace pas un avis juridique ou comptable.</p>
        </div>
      </div>
    </section>

    <SolutionMethod title="Quatre étapes, puis un suivi adapté." text="Le livrable est calibré selon la complexité du programme et les documents disponibles. Les décisions et prochaines échéances sont ensuite suivies avec l’entreprise." />

    <section class="section section--surface" aria-labelledby="faq-title">
      <div class="container faq-layout">
        <SectionHeader kicker="Questions fréquentes" title="Avant de lancer l’analyse." id="faq-title" />
        <FAQ items={faqItems} />
      </div>
    </section>

    <RelatedLinks items={[
      { href: '/assurances-entreprises/', label: 'Assurances entreprises', text: 'Comprendre le programme dans son ensemble.' },
      { href: '/assurance-transport/', label: 'Transport et logistique', text: 'Découvrir l’audit adapté aux risques de flux.' },
      { href: '/assurance-btp-decennale/', label: 'BTP et décennale', text: 'Revoir activités, attestations et garanties.' },
    ]} />
    <PageCTA title="Cadrons l’analyse utile à votre entreprise." text="Indiquez votre activité, le contrat prioritaire et votre prochaine échéance. Aucun document confidentiel n’est nécessaire au premier échange." />
  </main>
</SiteLayout>

<style>.faq-layout { max-width: 58rem; }</style>
